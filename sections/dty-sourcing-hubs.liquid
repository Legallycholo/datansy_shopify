<section class="dty-section dty-hubs">
  <div class="page-width">
    <div class="dty-section__header dty-reveal">
      {%- if section.settings.label != blank -%}
        <span class="dty-section__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <div class="dty-hubs__title-row">
        {%- if section.settings.heading != blank -%}
          <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.stat_badge != blank -%}
          <span class="dty-badge dty-hubs__badge">{{ section.settings.stat_badge }}</span>
        {%- endif -%}
      </div>
    </div>

    <div class="dty-hubs__grid">
      {%- for block in section.blocks -%}
        {%- assign reveal_delay = forloop.index | modulo: 6 -%}
        <div class="dty-hubs__card dty-card dty-reveal dty-reveal--delay-{{ reveal_delay }}" {{ block.shopify_attributes }}>
          <div class="dty-hubs__icon">
            <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon | default: 'location_on' }}</span>
          </div>
          <h3 class="dty-hubs__name">{{ block.settings.title }}</h3>
          {%- if block.settings.subtitle != blank -%}
            <p class="dty-hubs__subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Datansy Hubs",
  "tag": "section",
  "class": "section-dty-hubs",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Sourcing Internacional" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Compramos Donde Manda el Precio, Entregamos en Chile" },
    { "type": "text", "id": "stat_badge", "label": "Badge estadística", "default": "5 Hubs Globales de Abastecimiento" }
  ],
  "blocks": [
    {
      "type": "hub",
      "name": "Hub",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icono Material", "default": "location_on" },
        { "type": "text", "id": "title", "label": "Título", "default": "Hub" },
        { "type": "text", "id": "subtitle", "label": "Subtítulo", "default": "Centro de abastecimiento" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Hubs",
      "blocks": [
        { "type": "hub", "settings": { "title": "Dubai", "subtitle": "Emiratos Árabes Unidos", "icon": "flight_takeoff" } },
        { "type": "hub", "settings": { "title": "Singapur", "subtitle": "Sudeste Asiático", "icon": "hub" } },
        { "type": "hub", "settings": { "title": "Hong Kong", "subtitle": "Puerta de entrada a China", "icon": "sailing" } },
        { "type": "hub", "settings": { "title": "Estados Unidos", "subtitle": "Miami & Los Angeles", "icon": "public" } },
        { "type": "hub", "settings": { "title": "China (Shenzhen)", "subtitle": "Manufactura directa", "icon": "factory" } }
      ]
    }
  ]
}
{% endschema %}
