      "default": "+56 9 9136 9127"
    },
    {
      "type": "text",
      "id": "phone_intl",
      "label": "Teléfono internacional",
      "default": "+1 754 200 9891"
    },
    {
      "type": "text",
      "id": "phone_callcenter",
      "label": "Call center",
      "default": "+56 2 2938 1889"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "contacto@gsmpro.cl"
    },
    {
      "type": "textarea",
      "id": "hours",
