        { "type": "link", "settings": { "group": "menu", "title": "Realidad Virtual", "url": "/collections/realidad-virtual" } },
        { "type": "link", "settings": { "group": "menu", "title": "Computación", "url": "/collections/computacion" } },
        { "type": "link", "settings": { "group": "menu", "title": "Audio", "url": "/collections/audio" } },
        { "type": "link", "settings": { "group": "menu", "title": "Reacondicionados", "url": "/collections/reacondicionados" } },
        { "type": "link", "settings": { "group": "menu", "title": "Cotización", "url": "/pages/cotizaciones" } },
        { "type": "link", "settings": { "group": "menu", "title": "Rastrea tu Pedido", "url": "/pages/rastrea-tu-pedido" } }
