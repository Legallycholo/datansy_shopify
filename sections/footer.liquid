        { "type": "link", "settings": { "group": "nosotros", "title": "Contacto", "url": "/pages/contact" } },
        { "type": "link", "settings": { "group": "menu", "title": "Nuevos Lanzamientos", "url": "/collections/nuevos-lanzamientos" } },
        { "type": "link", "settings": { "group": "menu", "title": "Celulares", "url": "/collections/celulares" } },
