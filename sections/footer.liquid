{%- if section.settings.show_mission and section.settings.mission_text != blank -%}
  <div class="dty-footer__mission">
    <div class="page-width">
      <div class="dty-footer__mission-inner">
        <div class="dty-footer__mission-logo">
          {% render 'dty-logo',
            background: 'dark',
            class: 'dty-footer__mission-logo-img',
            link_class: 'dty-footer__mission-logo-link',
            width: 140,
            loading: 'lazy',
            link: true
          %}
        </div>
        <p class="dty-footer__mission-text">{{ section.settings.mission_text }}</p>
      </div>
    </div>
  </div>
{%- endif -%}

{%- if section.settings.show_newsletter -%}
  <div class="dty-footer__newsletter-band">
    <div class="page-width">
      <div class="dty-footer__newsletter-inner">
        <div class="dty-footer__newsletter-copy">
          <p class="dty-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</p>
          {%- if section.settings.newsletter_subtext != blank -%}
            <p class="dty-footer__newsletter-sub">{{ section.settings.newsletter_subtext }}</p>
          {%- endif -%}
        </div>
        {%- form 'customer', id: 'FooterNewsletterForm', class: 'dty-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="dty-footer__newsletter-success">{{ 'footer.newsletter_success' | t }}</p>
          {%- else -%}
            <div class="dty-footer__newsletter-fields">
              <input
                type="email"
                name="contact[email]"
                id="FooterNewsletterEmail"
                class="dty-footer__newsletter-input"
                placeholder="{{ 'footer.newsletter_placeholder' | t }}"
                autocomplete="email"
                required
                aria-label="{{ 'footer.newsletter_placeholder' | t }}"
              >
              <button type="submit" class="btn btn--accent dty-footer__newsletter-btn">
                {{ 'footer.newsletter_submit' | t }}
              </button>
            </div>
            {%- if form.errors -%}
              <p class="dty-footer__newsletter-error">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
{%- endif -%}

<footer class="dty-footer" data-section-id="{{ section.id }}" data-section-type="footer">
  <div class="dty-footer__main">
    <div class="page-width">
      <div class="dty-footer__grid">
        {%- comment -%} Column 1 — Nosotros {%- endcomment -%}
        <div class="dty-footer__column is-open" data-footer-column>
          <button type="button" class="dty-footer__column-toggle" data-footer-toggle aria-expanded="true">
            {{ section.settings.column_1_title }}
            <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
          </button>
          <div class="dty-footer__column-body">
            <nav class="dty-footer__links" aria-label="{{ section.settings.column_1_title }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'link' and block.settings.group == 'nosotros' -%}
                  {%- liquid
                    assign show_footer_link = true
                    if block.settings.url contains '/collections/'
                      assign footer_handle = block.settings.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
                      assign footer_collection = collections[footer_handle]
                      if footer_collection != blank and footer_collection.products_count == 0
                        assign show_footer_link = false
                      endif
                    endif
                  -%}
                  {%- if show_footer_link -%}
                  <a href="{{ block.settings.url }}" class="dty-footer__link" {{ block.shopify_attributes }}>
                    {{ block.settings.title }}
                  </a>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </nav>
          </div>
        </div>

        {%- comment -%} Column 2 — Tienda {%- endcomment -%}
        <div class="dty-footer__column" data-footer-column>
          <button type="button" class="dty-footer__column-toggle" data-footer-toggle aria-expanded="false">
            {{ section.settings.column_2_title }}
            <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
          </button>
          <div class="dty-footer__column-body">
            <nav class="dty-footer__links" aria-label="{{ section.settings.column_2_title }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'link' and block.settings.group == 'menu' -%}
                  {%- liquid
                    assign show_footer_link = true
                    if block.settings.url contains '/collections/'
                      assign footer_handle = block.settings.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
                      assign footer_collection = collections[footer_handle]
                      if footer_collection != blank and footer_collection.products_count == 0
                        assign show_footer_link = false
                      endif
                    endif
                  -%}
                  {%- if show_footer_link -%}
                  <a href="{{ block.settings.url }}" class="dty-footer__link" {{ block.shopify_attributes }}>
                    {{ block.settings.title }}
                  </a>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </nav>
          </div>
        </div>

        {%- comment -%} Column 3 — Legal {%- endcomment -%}
        <div class="dty-footer__column" data-footer-column>
          <button type="button" class="dty-footer__column-toggle" data-footer-toggle aria-expanded="false">
            {{ section.settings.column_3_title }}
            <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
          </button>
          <div class="dty-footer__column-body">
            <nav class="dty-footer__links" aria-label="{{ section.settings.column_3_title }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'link' and block.settings.group == 'legal' -%}
                  <a href="{{ block.settings.url }}" class="dty-footer__link" {{ block.shopify_attributes }}>
                    {{ block.settings.title }}
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </nav>
          </div>
        </div>

        {%- comment -%} Column 4 — Contacto {%- endcomment -%}
        <div class="dty-footer__column" data-footer-column>
          <button type="button" class="dty-footer__column-toggle" data-footer-toggle aria-expanded="false">
            {{ section.settings.contact_title }}
            <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
          </button>
          <div class="dty-footer__column-body">
            {%- if section.settings.whatsapp_cl != blank -%}
              <div class="dty-footer__contact-item">
                <span class="material-symbols-outlined" aria-hidden="true">chat</span>
                <div>
                  <strong>WhatsApp Chile</strong><br>
                  <a href="https://wa.me/{{ section.settings.whatsapp_cl | replace: '+', '' | replace: ' ', '' }}">{{ section.settings.whatsapp_cl }}</a>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.phone_intl != blank -%}
              <div class="dty-footer__contact-item">
                <span class="material-symbols-outlined" aria-hidden="true">call</span>
                <div>
                  <strong>Teléfono US</strong><br>
                  <a href="tel:+1{{ section.settings.phone_intl | replace: ' ', '' | replace: '-', '' }}">{{ section.settings.phone_intl }}</a>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.phone_cl != blank -%}
              <div class="dty-footer__contact-item">
                <span class="material-symbols-outlined" aria-hidden="true">call</span>
                <div>
                  <strong>Teléfono Chile</strong><br>
                  <a href="tel:{{ section.settings.phone_cl | replace: ' ', '' | replace: '-', '' }}">{{ section.settings.phone_cl }}</a>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.phone_callcenter != blank -%}
              <div class="dty-footer__contact-item">
                <span class="material-symbols-outlined" aria-hidden="true">call</span>
                <div>
                  <strong>Call center</strong><br>
                  <a href="tel:{{ section.settings.phone_callcenter | replace: ' ', '' }}">{{ section.settings.phone_callcenter }}</a>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.email != blank -%}
              <div class="dty-footer__contact-item">
                <span class="material-symbols-outlined" aria-hidden="true">mail</span>
                <div>
                  <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.hours != blank -%}
              <div class="dty-footer__hours">{{ section.settings.hours }}</div>
            {%- endif -%}
            {%- if section.settings.address != blank -%}
              <div class="dty-footer__contact-item">
                <span class="material-symbols-outlined" aria-hidden="true">location_on</span>
                <div>{{ section.settings.address | newline_to_br }}</div>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="dty-footer__bottom">
    <div class="page-width">
      <div class="dty-footer__bottom-inner">
        <div class="dty-footer__localization">
          {% render 'dty-localization', class_prefix: 'dty-localization dty-localization--footer', form_id: 'FooterLocalizationForm', compact: true %}
        </div>

        {%- unless shop.enabled_payment_types == empty -%}
          <div class="dty-footer__payments" aria-label="Medios de pago aceptados">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'dty-footer__payment-svg' }}
            {%- endfor -%}
          </div>
        {%- endunless -%}

        {%- if section.settings.social_facebook != blank or section.settings.social_instagram != blank or section.settings.social_twitter != blank or section.settings.social_youtube != blank or section.settings.social_tiktok != blank or section.settings.social_linkedin != blank -%}
          <nav class="dty-footer__social" aria-label="{{ 'footer.social_media' | t }}">
            {% render 'dty-social-links', settings: section.settings, link_class: 'dty-footer__social-link' %}
          </nav>
        {%- endif -%}

        <button type="button" class="dty-footer__back-to-top" data-back-to-top aria-label="Volver arriba">
          <span class="material-symbols-outlined" aria-hidden="true">arrow_upward</span>
        </button>
      </div>

      <div style="margin-top: var(--space-6); text-align: center;">
        {%- if section.settings.recaptcha_notice != blank -%}
          <p class="dty-footer__legal">{{ section.settings.recaptcha_notice }}</p>
        {%- endif -%}
        <p class="dty-footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
          {%- if section.settings.copyright_text != blank -%}
            {{ section.settings.copyright_text }}
          {%- endif -%}
        </p>
      </div>
    </div>
  </div>
</footer>

