      "default": "Lun–Vie 7:00–23:00\nSab–Dom 9:00–22:00"
    },
    {
      "type": "header",
      "content": "Redes sociales"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter / X"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn"
    },
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "textarea",
      "id": "recaptcha_notice",
      "label": "Aviso reCAPTCHA",
      "default": "Este sitio está protegido por reCAPTCHA y se aplican la Política de Privacidad y los Términos de Servicio de Google."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Texto copyright adicional",
      "default": "Todos los derechos reservados."
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Enlace",
      "settings": [
        {
          "type": "select",
          "id": "group",
          "label": "Columna",
          "options": [
            { "value": "nosotros", "label": "Nosotros" },
            { "value": "menu", "label": "Menú 2026" }
          ],
          "default": "nosotros"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Enlace"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer GSMPRO",
      "blocks": [
        { "type": "link", "settings": { "group": "nosotros", "title": "Quienes Somos", "url": "/pages/sobre-nosotros" } },
        { "type": "link", "settings": { "group": "nosotros", "title": "Referidos", "url": "/pages/referidos" } },
