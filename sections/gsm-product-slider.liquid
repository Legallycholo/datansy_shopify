{%- liquid
  assign collection = collections[section.settings.collection]
  assign product_limit = section.settings.products_to_show | default: 12
  assign view_more_url = section.settings.view_more_url
  if view_more_url == blank and collection != blank
    assign view_more_url = collection.url
  endif
-%}

<section class="gsm-section gsm-product-slider" data-product-slider aria-roledescription="carousel">
  <div class="page-width">
    <div class="gsm-product-slider__header">
      <div>
        {%- if section.settings.label != blank -%}
          <span class="gsm-section__label">{{ section.settings.label }}</span>
        {%- endif -%}
        <h2 class="gsm-section__heading">{{ section.settings.heading | default: collection.title }}</h2>
      </div>
      <div class="gsm-product-slider__controls">
        {%- if view_more_url != blank -%}
          <a href="{{ view_more_url }}" class="gsm-product-slider__view-more">
            {{ section.settings.view_more_label }}
            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
          </a>
        {%- endif -%}
        <div class="gsm-product-slider__arrows">
          <button type="button" class="gsm-product-slider__arrow" data-slider-prev aria-label="{{ 'accessibility.slider_prev' | t }}">
            <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
          </button>
          <button type="button" class="gsm-product-slider__arrow" data-slider-next aria-label="{{ 'accessibility.slider_next' | t }}">
            <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="gsm-product-slider__track-wrap page-width">
    <div class="gsm-product-slider__track" data-slider-track tabindex="0" aria-label="{{ section.settings.heading | default: collection.title | escape }}">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: product_limit -%}
          <div class="gsm-product-slider__slide">
            {% render 'gsm-product-card', product: product, show_quick_add: section.settings.show_quick_add %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="gsm-product-slider__slide">
            <article class="gsm-product-card gsm-product-card--placeholder">
              <div class="placeholder-image placeholder-image--square">Producto placeholder</div>
              <p class="gsm-product-card__title">{{ section.settings.heading }} — producto {{ i }}</p>
            </article>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GSMPRO Product Slider",
  "tag": "section",
  "class": "section-gsm-product-slider",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Productos destacados" },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "range", "id": "products_to_show", "min": 4, "max": 20, "step": 1, "label": "Productos a mostrar", "default": 12 },
    { "type": "text", "id": "view_more_label", "label": "Enlace ver más", "default": "Ver más" },
    { "type": "url", "id": "view_more_url", "label": "URL ver más" },
    { "type": "checkbox", "id": "show_quick_add", "label": "Mostrar añadir al carrito", "default": true }
  ],
  "presets": [{ "name": "GSMPRO Product Slider" }]
}
{% endschema %}
