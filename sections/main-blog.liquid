{%- paginate blog.articles by section.settings.posts_per_page -%}

<section class="dty-blog page-width">
  <header class="dty-blog__header">
    {%- if section.settings.label != blank -%}
      <span class="dty-blog__label">{{ section.settings.label }}</span>
    {%- endif -%}
    <h1 class="dty-blog__title">{{ section.settings.heading | default: blog.title }}</h1>
  </header>

  {%- if blog.articles.size > 0 -%}
    <div class="dty-blog__grid">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="dty-blog__card dty-card">
          {%- if article.image -%}
            {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'dty-blog__card-image', alt: article.title }}
          {%- else -%}
            <div class="placeholder-image dty-blog__card-image" style="border-radius: var(--radius-xl) var(--radius-xl) 0 0;">Blog</div>
          {%- endif -%}
          <div class="dty-blog__card-body">
            <time class="dty-blog__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{ article.published_at | date: '%d/%m/%Y' }}
            </time>
            <h2 class="dty-blog__card-title">{{ article.title }}</h2>
            <p class="dty-blog__card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p>
            <span class="dty-blog__card-link">{{ 'blog.read_more' | t }} →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="dty-collection__pagination" style="margin-top: var(--space-10);">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&laquo;</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}<span class="current">{{ part.title }}</span>
          {%- else -%}<span>{{ part.title }}</span>{%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">&raquo;</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- else -%}
    <p style="text-align: center; color: var(--dty-text-muted); padding: var(--space-10);">{{ 'blog.empty' | t }}</p>
  {%- endif -%}
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Blog",
  "class": "section-main-blog",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Blog" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Datansy News - Tecnología y Noticias" },
    { "type": "range", "id": "posts_per_page", "min": 6, "max": 24, "step": 3, "label": "Artículos por página", "default": 12 }
  ]
}
{% endschema %}
