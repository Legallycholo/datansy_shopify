{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign color_option_names = 'Color,Colour,Colore,Couleur' | split: ','
-%}

<section class="dty-product page-width" data-product-section data-section-id="{{ section.id }}">
  <div class="dty-product__grid">
    {%- comment -%} Gallery {%- endcomment -%}
    <div class="dty-product-gallery">
      <div class="dty-product-gallery__main">
        {%- if product.featured_media -%}
          <img
            src="{{ product.featured_media | image_url: width: 800 }}"
            srcset="{{ product.featured_media | image_url: width: 400 }} 400w, {{ product.featured_media | image_url: width: 800 }} 800w, {{ product.featured_media | image_url: width: 1200 }} 1200w"
            sizes="(min-width: 1024px) 44vw, 100vw"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            width="{{ product.featured_media.width | default: 800 }}"
            height="{{ product.featured_media.height | default: 800 }}"
            data-gallery-main
            loading="eager"
            fetchpriority="high"
          >
        {%- else -%}
          <div class="placeholder-image placeholder-image--square">Product image placeholder</div>
        {%- endif -%}
        {%- if product.media.size > 1 -%}
          <button type="button" class="dty-gallery-arrow dty-gallery-arrow--prev" data-gallery-prev aria-label="{{ 'accessibility.slider_prev' | t }}">
            <span class="material-symbols-outlined">chevron_left</span>
          </button>
          <button type="button" class="dty-gallery-arrow dty-gallery-arrow--next" data-gallery-next aria-label="{{ 'accessibility.slider_next' | t }}">
            <span class="material-symbols-outlined">chevron_right</span>
          </button>
        {%- endif -%}
      </div>
      {%- if product.media.size > 1 -%}
        <div class="dty-product-gallery__thumbs">
          {%- for media in product.media -%}
            <button
              type="button"
              class="dty-product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-gallery-thumb
              data-media-id="{{ media.id }}"
              data-full-src="{{ media | image_url: width: 800 }}"
              aria-label="{{ 'products.media_gallery' | t }} {{ forloop.index }}"
            >
              {{ media | image_url: width: 144 | image_tag: loading: 'lazy', decoding: 'async', alt: media.alt }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Product info {%- endcomment -%}
    <div class="dty-product-info">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}

          {%- when 'vendor' -%}
            {%- if product.vendor != blank -%}
              <p class="dty-product-info__vendor" {{ block.shopify_attributes }}>
                <a href="{{ routes.collections_url }}/vendors?q={{ product.vendor | url_param_escape }}">{{ product.vendor }}</a>
              </p>
            {%- endif -%}

          {%- when 'title' -%}
            <div class="product__title" {{ block.shopify_attributes }}>
              <h1 class="dty-product-info__title">{{ product.title }}</h1>
              {%- if block.settings.show_subtitle and block.settings.subtitle != blank -%}
                <p class="dty-product-info__subtitle">{{ block.settings.subtitle }}</p>
              {%- endif -%}
            </div>

          {%- when 'reviews' -%}
            {%- if block.settings.show_placeholder_reviews -%}
            <div class="dty-product-info__reviews" {{ block.shopify_attributes }}>
              {% render 'dty-stars', rating: 5 %}
              {%- if block.settings.review_count != blank -%}
                <span class="dty-product-card__review-count">({{ block.settings.review_count }})</span>
              {%- else -%}
                <span class="dty-product-card__review-count">({{ 'products.reviews_placeholder' | t }})</span>
              {%- endif -%}
            </div>
            {%- endif -%}

          {%- when 'price' -%}
            <div class="dty-product-info__price-block" {{ block.shopify_attributes }}>
              <div class="dty-price" data-product-price>
                {% render 'dty-product-price', product: product, variant: current_variant, show_savings: true %}
              </div>
              {%- if block.settings.show_sku -%}
                <p class="dty-product-info__sku" data-product-sku>
                  {%- if current_variant.sku != blank -%}SKU: {{ current_variant.sku }}{%- endif -%}
                </p>
              {%- endif -%}
            </div>

          {%- when 'feature_bullets' -%}
            <ul class="dty-feature-bullets" {{ block.shopify_attributes }}>
              {%- if block.settings.bullet_1 != blank -%}
                <li class="dty-feature-bullets__item">
                  <span class="material-symbols-outlined dty-feature-bullets__icon" aria-hidden="true">{{ block.settings.icon_1 | default: 'check_circle' }}</span>
                  <span>{{ block.settings.bullet_1 }}</span>
                </li>
              {%- endif -%}
              {%- if block.settings.bullet_2 != blank -%}
                <li class="dty-feature-bullets__item">
                  <span class="material-symbols-outlined dty-feature-bullets__icon" aria-hidden="true">{{ block.settings.icon_2 | default: 'check_circle' }}</span>
                  <span>{{ block.settings.bullet_2 }}</span>
                </li>
              {%- endif -%}
              {%- if block.settings.bullet_3 != blank -%}
                <li class="dty-feature-bullets__item">
                  <span class="material-symbols-outlined dty-feature-bullets__icon" aria-hidden="true">{{ block.settings.icon_3 | default: 'check_circle' }}</span>
                  <span>{{ block.settings.bullet_3 }}</span>
                </li>
              {%- endif -%}
            </ul>

          {%- when 'variant_picker' -%}
            {%- unless product.has_only_default_variant -%}
              <variant-selects class="dty-variant-picker" {{ block.shopify_attributes }}>
                {%- for option in product.options_with_values -%}
                  {%- assign is_color = false -%}
                  {%- if color_option_names contains option.name -%}
                    {%- assign is_color = true -%}
                  {%- endif -%}
                  <div
                    class="dty-variant-picker__group"
                    role="group"
                    aria-labelledby="variant-option-{{ section.id }}-{{ option.position }}"
                  >
                    <p
                      class="dty-variant-picker__label"
                      id="variant-option-{{ section.id }}-{{ option.position }}"
                    >
                      {{ option.name }}
                    </p>
                    <div class="dty-variant-picker__options">
                      {%- for value in option.values -%}
                        {%- assign option_index = option.position | minus: 1 -%}
                        {%- assign matched_variant = nil -%}
                        {%- for variant in product.variants -%}
                          {%- if variant.options[option_index] == value -%}
                            {%- assign matched_variant = variant -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                        {%- assign swatch_style = '' -%}
                        {%- assign swatch_has_image = false -%}
                        {%- if is_color -%}
                          {%- assign color_hex = matched_variant.metafields.custom.color_hex | default: matched_variant.metafields.custom.color | default: '' -%}
                          {%- if color_hex != blank -%}
                            {%- assign swatch_style = 'background-color:' | append: color_hex -%}
                          {%- elsif matched_variant.featured_media != blank -%}
                            {%- assign swatch_img = matched_variant.featured_media | image_url: width: 72 -%}
                            {%- assign swatch_style = 'background-image:url(' | append: swatch_img | append: ')' -%}
                            {%- assign swatch_has_image = true -%}
                          {%- endif -%}
                        {%- endif -%}
                        <label class="dty-variant-picker__option" title="{{ value | escape }}">
                          <input
                            type="radio"
                            name="option-{{ option.position }}"
                            value="{{ value | escape }}"
                            data-option-input
                            data-option-position="{{ option.position }}"
                            aria-label="{{ option.name }}: {{ value | escape }}"
                            {% if option.selected_value == value %}checked{% endif %}
                            {% unless matched_variant.available %}disabled{% endunless %}
                          >
                          <span
                            class="dty-variant-picker__swatch{% if is_color %} dty-variant-picker__color{% endif %}{% if swatch_has_image %} dty-variant-picker__color--image{% endif %}"
                            {% if is_color %}data-color-value="{{ value | handleize }}"{% endif %}
                            {% if swatch_style != blank %}style="{{ swatch_style }}"{% endif %}
                          >
                            {%- if is_color -%}
                              <span class="visually-hidden">{{ value }}</span>
                            {%- else -%}
                              {{ value }}
                            {%- endif -%}
                          </span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endfor -%}
              </variant-selects>
            {%- endunless -%}

          {%- when 'buy_buttons' -%}
            {%- assign threshold_cents = settings.free_shipping_threshold | default: 50000 | times: 100 -%}
            <div class="dty-product-shipping-info" data-product-shipping-info>
              {%- if current_variant.price >= threshold_cents -%}
                <span class="dty-product-shipping-info__badge dty-product-shipping-info__badge--free">
                  <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
                  Envío gratis incluido
                </span>
              {%- else -%}
                <span class="dty-product-shipping-info__badge">
                  <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
                  Envío gratis sobre $50.000
                </span>
              {%- endif -%}
              <span class="dty-product-shipping-info__delivery">
                <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
                Entrega estimada: 2–5 días hábiles
              </span>
            </div>

            {%- form 'product', product, data-product-form: true, class: 'dty-product-form' -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}">

              <div class="dty-product-form__qty">
                <button type="button" class="dty-product-form__qty-btn" data-qty-change="-1" aria-label="-">−</button>
                <input class="dty-product-form__qty-input" type="number" name="quantity" value="1" min="1" data-qty-input aria-label="{{ 'cart.quantity' | t }}">
                <button type="button" class="dty-product-form__qty-btn" data-qty-change="1" aria-label="+">+</button>
              </div>

              <div class="dty-product-form__actions">
                <button
                  type="submit"
                  name="add"
                  class="btn btn--primary dty-product-form__submit product-form__submit"
                  data-product-submit
                  data-available-text="{{ block.settings.atc_text | default: 'products.add_to_cart' | t }} — {{ block.settings.atc_subtext | default: 'Envío Gratis' }}"
                  data-sold-out-text="{{ 'products.sold_out' | t }}"
                  {% unless current_variant.available %}disabled{% endunless %}
                >
                  <span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span>
                  <span class="dty-product-form__submit-text">
                    {%- if current_variant.available -%}
                      {{ block.settings.atc_text | default: 'products.add_to_cart' | t }} — {{ block.settings.atc_subtext | default: 'Envío Gratis' }}
                    {%- else -%}
                      {{ 'products.sold_out' | t }}
                    {%- endif -%}
                  </span>
                </button>
                {{ form | payment_button }}
              </div>
            {%- endform -%}

            {%- comment -%} Urgency / social proof {%- endcomment -%}
            <div class="dty-urgency" data-urgency>
              {%- if block.settings.show_urgency -%}
                <p class="dty-urgency__viewers">
                  <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                  <span data-viewer-count>{{ block.settings.viewer_base | default: 24 }}</span> personas están viendo este producto
                </p>
              {%- endif -%}
              {%- if current_variant.available -%}
                <p class="dty-urgency__stock">
                  <span class="material-symbols-outlined" aria-hidden="true">inventory</span>
                  En Stock — Envío dentro de 24 hrs
                </p>
              {%- endif -%}
            </div>

          {%- when 'share' -%}
            {%- liquid
              assign share_whatsapp = section.settings.whatsapp_number | default: '+56991369127'
              assign share_whatsapp_digits = share_whatsapp | replace: '+', '' | replace: ' ', ''
            -%}
            <div class="dty-product-form__share" {{ block.shopify_attributes }}>
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: product.url | url_encode }}" target="_blank" rel="noopener" aria-label="Facebook">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6 4.39 10.97 10.13 11.85v-8.38H7.08v-3.47h3.05V9.41c0-3.02 1.79-4.7 4.53-4.7 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.47h-2.8v8.38C19.61 23.04 24 18.07 24 12.07Z"/></svg>
              </a>
              <a href="https://twitter.com/intent/tweet?url={{ shop.url | append: product.url | url_encode }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" aria-label="X">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.46l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93Zm-1.29 19.5h2.04L6.49 3.24H4.3L17.61 20.65Z"/></svg>
              </a>
              <a href="https://wa.me/{{ share_whatsapp_digits }}?text={{ product.title | url_encode }}%20{{ shop.url | append: product.url | url_encode }}" target="_blank" rel="noopener" aria-label="WhatsApp">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M.06 24l1.68-6.15a11.87 11.87 0 0 1-1.59-5.95C.16 5.34 5.5 0 12.06 0a11.82 11.82 0 0 1 8.41 3.49 11.82 11.82 0 0 1 3.48 8.42c0 6.56-5.34 11.9-11.9 11.9a11.9 11.9 0 0 1-5.69-1.45L.06 24ZM6.6 20.13c1.68 1 3.28 1.6 5.46 1.6 5.45 0 9.89-4.43 9.89-9.88 0-5.46-4.42-9.89-9.88-9.89-5.46 0-9.89 4.43-9.89 9.89 0 2.29.67 4 1.8 5.66l-1 3.64 3.62-1.02Zm10.96-5.45c-.07-.12-.27-.2-.57-.35-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.39-1.47-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.29.17-1.42Z"/></svg>
              </a>
            </div>

          {%- when 'warehouse' -%}
            {% render 'dty-warehouse-availability', product: product, variant: current_variant, block: block %}

          {%- when 'trust_badges' -%}
            <div class="dty-trust-badges" {{ block.shopify_attributes }}>
              <div class="dty-trust-badges__item">
                <span class="material-symbols-outlined dty-trust-badges__icon">verified</span>
                <div class="dty-trust-badges__text">
                  <strong>Garantía Oficial</strong>
                  <span>Respaldo directo del fabricante</span>
                </div>
              </div>
              <div class="dty-trust-badges__item">
                <span class="material-symbols-outlined dty-trust-badges__icon">local_shipping</span>
                <div class="dty-trust-badges__text">
                  <strong>Envío a todo Chile</strong>
                  <span>Gratis sobre $50.000</span>
                </div>
              </div>
              <div class="dty-trust-badges__item">
                <span class="material-symbols-outlined dty-trust-badges__icon">lock</span>
                <div class="dty-trust-badges__text">
                  <strong>Compra Segura</strong>
                  <span>SSL + Pago encriptado</span>
                </div>
              </div>
              <div class="dty-trust-badges__item">
                <span class="material-symbols-outlined dty-trust-badges__icon">replay</span>
                <div class="dty-trust-badges__text">
                  <strong>Devoluciones</strong>
                  <span>Política Datansy garantizada</span>
                </div>
              </div>
            </div>

          {%- when 'why_buy' -%}
            <div class="dty-why-buy" {{ block.shopify_attributes }}>
              <p class="dty-why-buy__heading">
                <span class="material-symbols-outlined" aria-hidden="true">workspace_premium</span>
                {{ block.settings.heading | default: '¿Por qué comprar con nosotros?' }}
              </p>
              <ul class="dty-why-buy__list">
                {%- if block.settings.point_1 != blank -%}
                  <li>{{ block.settings.point_1 }}</li>
                {%- endif -%}
                {%- if block.settings.point_2 != blank -%}
                  <li>{{ block.settings.point_2 }}</li>
                {%- endif -%}
                {%- if block.settings.point_3 != blank -%}
                  <li>{{ block.settings.point_3 }}</li>
                {%- endif -%}
                {%- if block.settings.point_4 != blank -%}
                  <li>{{ block.settings.point_4 }}</li>
                {%- endif -%}
              </ul>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Tabs {%- endcomment -%}
  <div class="dty-product-tabs">
    <div class="dty-product-tabs__nav" role="tablist">
      <button type="button" class="dty-product-tabs__btn is-active" data-tab-btn="description" role="tab">{{ 'products.description' | t }}</button>
      <button type="button" class="dty-product-tabs__btn" data-tab-btn="specs" role="tab">{{ 'products.specifications' | t }}</button>
      <button type="button" class="dty-product-tabs__btn" data-tab-btn="shipping" role="tab">{{ 'products.shipping_returns' | t }}</button>
    </div>
    <div class="dty-product-tabs__panel is-active rte product__description" data-tab-panel="description" role="tabpanel">
      {{ product.description }}
    </div>
    <div class="dty-product-tabs__panel rte" data-tab-panel="specs" role="tabpanel">
      {%- if product.metafields.custom.specifications != blank -%}
        {{ product.metafields.custom.specifications | metafield_tag }}
      {%- else -%}
        <p>{{ 'products.specs_placeholder' | t }}</p>
      {%- endif -%}
    </div>
    <div class="dty-product-tabs__panel rte" data-tab-panel="shipping" role="tabpanel">
      {{ section.settings.shipping_returns_text }}
    </div>
  </div>

  {%- comment -%} Vitals product reviews anchor (product_end) {%- endcomment -%}
  <div id="vitals-product-reviews" class="vitals-product-reviews page-width" data-vitals-product-end></div>

  <script type="application/json" data-product-json>{{ product | json }}</script>
</section>

<div class="dty-product-sticky" data-product-sticky>
  <div class="dty-product-sticky__inner">
    <div class="dty-product-sticky__info">
      <span class="dty-product-sticky__price" data-sticky-price>{%- render 'dty-money', amount: current_variant.price -%}</span>
      <span class="dty-product-sticky__shipping">Envío Gratis</span>
    </div>
    <button
      type="button"
      name="add"
      class="btn btn--primary dty-product-sticky__btn product-form__submit"
      data-sticky-atc
      data-available-text="{{ 'products.add_to_cart' | t }}"
      data-sold-out-text="{{ 'products.sold_out' | t }}"
      {% unless current_variant.available %}disabled{% endunless %}
    >
      <span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span>
      {{ 'products.add_to_cart' | t }}
    </button>
  </div>
</div>

{% schema %}
{
  "name": "Producto",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "richtext",
      "id": "shipping_returns_text",
      "label": "Envío y devoluciones",
      "default": "<p>Envíos a todo Chile en 2–5 días hábiles. Envío gratis en compras sobre $50.000.</p><p><a href=\"/policies/shipping-policy\">Política de envíos</a> · <a href=\"/policies/refund-policy\">Política de devoluciones</a></p>"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp (compartir producto)",
      "default": "+56 9 9136 9127"
    }
  ],
  "blocks": [
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    {
      "type": "title",
      "name": "Título",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_subtitle", "label": "Mostrar subtítulo", "default": true },
        { "type": "text", "id": "subtitle", "label": "Subtítulo (beneficio principal)", "default": "Escucha tu música sin bloquear el sonido del entorno" }
      ]
    },
    { "type": "reviews", "name": "Reseñas (placeholder)", "limit": 1, "settings": [
      { "type": "checkbox", "id": "show_placeholder_reviews", "label": "Mostrar estrellas placeholder", "default": true, "info": "Desactivado por defecto. Usa Vitals u otra app de reseñas." },
      { "type": "text", "id": "review_count", "label": "Texto del contador", "default": "127 reseñas" }
    ] },
    {
      "type": "price",
      "name": "Precio",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_sku", "label": "Mostrar SKU", "default": true }
      ]
    },
    {
      "type": "feature_bullets",
      "name": "Características clave",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "bullet_1", "label": "Característica 1", "default": "Conducción Ósea — No bloquea tus oídos" },
        { "type": "text", "id": "icon_1", "label": "Ícono 1 (Material Symbols)", "default": "hearing" },
        { "type": "text", "id": "bullet_2", "label": "Característica 2", "default": "Bluetooth 5.3 + IPX5 — Para deportes al aire libre" },
        { "type": "text", "id": "icon_2", "label": "Ícono 2 (Material Symbols)", "default": "bluetooth" },
        { "type": "text", "id": "bullet_3", "label": "Característica 3", "default": "Solo 25g — Ultraliviano, úsalo todo el día" },
        { "type": "text", "id": "icon_3", "label": "Ícono 3 (Material Symbols)", "default": "fitness_center" }
      ]
    },
    { "type": "variant_picker", "name": "Selector de variantes", "limit": 1 },
    {
      "type": "buy_buttons",
      "name": "Botones de compra",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "atc_text", "label": "Texto del botón ATC", "default": "Agregar al Carrito" },
        { "type": "text", "id": "atc_subtext", "label": "Subtexto ATC (después del guión)", "default": "Envío Gratis" },
        { "type": "checkbox", "id": "show_urgency", "label": "Mostrar social proof (viewers)", "default": true },
        { "type": "range", "id": "viewer_base", "label": "Base de viewers", "min": 10, "max": 99, "step": 1, "default": 24 }
