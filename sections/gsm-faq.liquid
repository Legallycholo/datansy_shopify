<section class="gsm-section gsm-faq">
  <div class="page-width gsm-faq__inner">
    <div class="gsm-faq__header">
      {%- if section.settings.label != blank -%}
        <span class="gsm-section__label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="gsm-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="gsm-faq__list" role="region" aria-label="{{ section.settings.heading | default: section.settings.label | escape }}">
      {%- for block in section.blocks -%}
        <div class="gsm-faq__item" data-faq-item {{ block.shopify_attributes }}>
          <button
            type="button"
            class="gsm-faq__question"
            data-faq-toggle
            id="FaqQuestion-{{ block.id }}"
            aria-expanded="false"
            aria-controls="FaqAnswer-{{ block.id }}"
          >
            <span>
              <span class="gsm-faq__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              {{ block.settings.question }}
            </span>
            <span class="material-symbols-outlined gsm-faq__chevron" aria-hidden="true">expand_more</span>
          </button>
          <div id="FaqAnswer-{{ block.id }}" class="gsm-faq__answer" data-faq-answer role="region" aria-labelledby="FaqQuestion-{{ block.id }}" hidden>
            <div class="gsm-faq__answer-inner rte">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Datansy FAQ",
  "tag": "section",
  "class": "section-gsm-faq",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Preguntas Frecuentes" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Transparencia Total" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Pregunta",
      "settings": [
        { "type": "text", "id": "question", "label": "Pregunta", "default": "¿Pregunta?" },
        { "type": "richtext", "id": "answer", "label": "Respuesta", "default": "<p>Respuesta placeholder.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Los productos tienen garantía?",
            "answer": "<p>Sí. Todos nuestros productos cuentan con garantía oficial del fabricante y respaldo Datansy. El plazo varía según la marca y categoría.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Cuáles son los medios de pago?",
            "answer": "<p>Aceptamos tarjetas de crédito y débito (Visa, Mastercard, Amex), transferencia bancaria, PayPal, Apple Pay y Google Pay.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Hacen envíos a regiones?",
            "answer": "<p>Sí, enviamos a todo Chile incluyendo regiones extremas. Los tiempos de entrega varían según la ubicación.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Tienen tienda física?",
            "answer": "<p>Operamos principalmente online con centros de distribución en Santiago. Puedes contactarnos para coordinar retiro cuando esté disponible.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "¿Debo preocuparme por el \"Aduanazo\"?",
            "answer": "<p>No. Datansy gestiona toda la importación de forma legal y transparente. Los precios publicados incluyen los costos aplicables para compras en Chile.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
