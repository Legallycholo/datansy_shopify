<section class="gsm-section gsm-blog-strip">
  <div class="page-width">
    <div class="gsm-section__header gsm-section__header--center">
      {%- if section.settings.heading != blank -%}
        <h2 class="gsm-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    <div class="gsm-blog-strip__grid">
      {%- assign blog = blogs[section.settings.blog] -%}
      {%- if blog != blank -%}
        {%- for article in blog.articles limit: section.settings.posts_to_show -%}
          <a href="{{ article.url }}" class="gsm-blog-strip__card gsm-card">
            {%- if article.image -%}
              {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'gsm-blog-strip__image', alt: article.title }}
            {%- else -%}
              <div class="placeholder-image gsm-blog-strip__image">Blog</div>
            {%- endif -%}
            <div class="gsm-blog-strip__info">
              <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" class="gsm-blog-strip__date">{{ article.published_at | date: '%d/%m/%Y' }}</time>
              <h3 class="gsm-blog-strip__title">{{ article.title }}</h3>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="gsm-blog-strip__card gsm-card">
            <div class="placeholder-image gsm-blog-strip__image">GSM News</div>
            <div class="gsm-blog-strip__info">
              <p class="gsm-blog-strip__title">Artículo placeholder {{ i }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .gsm-blog-strip__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 768px) { .gsm-blog-strip__grid { grid-template-columns: repeat(3, 1fr); } }
  .gsm-blog-strip__card { overflow: hidden; text-decoration: none; color: inherit; padding: 0; }
  .gsm-blog-strip__image { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius-xl) var(--radius-xl) 0 0; }
  .gsm-blog-strip__info { padding: var(--space-4); }
  .gsm-blog-strip__date { font-size: var(--text-xs); color: var(--gsm-text-muted); }
  .gsm-blog-strip__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; margin: var(--space-2) 0 0; }
</style>

{% schema %}
{
  "name": "GSMPRO Blog strip",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "GSM News - Tecnología y Noticias" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "posts_to_show", "min": 2, "max": 6, "step": 1, "label": "Artículos", "default": 3 }
  ],
  "presets": [{ "name": "GSMPRO Blog strip" }]
}
{% endschema %}
