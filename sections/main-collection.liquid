{%- paginate collection.products by section.settings.products_per_page -%}

<section class="dty-collection page-width">
  {%- if collection.image -%}
    <div class="dty-collection__banner">
      {{ collection.image | image_url: width: 1400 | image_tag: loading: 'eager', class: 'dty-collection__banner-img', alt: collection.title }}
    </div>
  {%- endif -%}

  <div class="dty-collection__header">
    <div>
      <h1 class="dty-collection__title">{{ collection.title }}</h1>
      <p class="dty-collection__count">{{ 'collections.products_count' | t: count: collection.products_count }}</p>
      {%- if collection.description != blank -%}
        <div class="rte" style="margin-top: var(--space-3); color: var(--dty-text-muted); font-size: var(--text-sm);">{{ collection.description }}</div>
      {%- endif -%}
    </div>
    <div class="dty-collection__toolbar">
      <button type="button" class="dty-collection__filter-toggle" data-filter-toggle>
        <span class="material-symbols-outlined" aria-hidden="true">tune</span>
        {{ 'collections.filters' | t }}
      </button>
      <div class="dty-collection__sort">
        <label class="visually-hidden" for="SortBy">{{ 'collections.sort_by' | t }}</label>
        <select id="SortBy" name="sort_by" onchange="window.location.href=this.value">
          {%- for option in collection.sort_options -%}
            <option value="{{ collection.url }}?sort_by={{ option.value }}"{% if option.value == collection.sort_by %} selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    </div>
  </div>

  {%- if collection.filters.size > 0 -%}
    <div class="dty-collection__active-filters">
      {%- for filter in collection.filters -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value or filter.max_value.value -%}
            <span class="dty-collection__active-tag">
              {%- capture filter_min -%}{% render 'dty-money', amount: filter.min_value.value %}{%- endcapture -%}
              {%- capture filter_max -%}{% render 'dty-money', amount: filter.max_value.value %}{%- endcapture -%}
              {{ filter_min }} – {{ filter_max }}
              <a href="{{ filter.url_to_remove }}">×</a>
            </span>
          {%- endif -%}
        {%- else -%}
          {%- for value in filter.active_values -%}
            <span class="dty-collection__active-tag">
              {{ filter.label }}: {{ value.label }}
              <a href="{{ value.url_to_remove }}">×</a>
            </span>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="dty-collection__layout">
    <aside class="dty-collection__filters" data-collection-filters>
      <div class="dty-collection__filters-header">
        <h2 class="dty-section__heading" style="font-size: var(--text-lg); margin: 0;">{{ 'collections.filters' | t }}</h2>
        <button type="button" data-filter-close aria-label="{{ 'general.close' | t }}">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <form id="CollectionFiltersForm" action="{{ collection.url }}" method="get">
        <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
        {%- for filter in collection.filters -%}
          <div class="dty-collection__filter-group">
            <p class="dty-collection__filter-title">{{ filter.label }}</p>
            <div class="dty-collection__filter-list">
              {%- case filter.type -%}
                {%- when 'list' -%}
                  {%- for value in filter.values -%}
                    <div class="dty-collection__filter-item">
                      <label>
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"{% if value.active %} checked{% endif %}{% if value.count == 0 and value.active == false %} disabled{% endif %} onchange="this.form.submit()">
                        {{ value.label }} ({{ value.count }})
                      </label>
                    </div>
                  {%- endfor -%}
                {%- when 'price_range' -%}
                  <div class="dty-collection__filter-item">
                    <input type="number" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: '.', '' }}" placeholder="{{ 'collections.filter_min' | t }}" min="0">
                    –
                    <input type="number" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: '.', '' }}" placeholder="{{ 'collections.filter_max' | t }}" min="0">
                    <button type="submit">{{ 'collections.apply' | t }}</button>
                  </div>
              {%- endcase -%}
            </div>
          </div>
        {%- endfor -%}
      </form>
    </aside>

    <div class="dty-collection__products">
      {%- if collection.products.size > 0 -%}
        <div class="dty-collection__grid">
          {%- for product in collection.products -%}
            {% render 'dty-product-card', product: product, show_quick_add: section.settings.show_quick_add %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="dty-collection__pagination" aria-label="{{ 'general.pagination' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}">&laquo;</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="current">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}">&raquo;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="dty-collection__empty">
          <p>{{ 'collections.empty' | t }}</p>
          {%- assign empty_cta = section.settings.empty_cta_url | default: '/collections/coleccion-principal' -%}
          <a href="{{ empty_cta }}" class="btn btn--primary">
            {%- if section.settings.empty_cta_label != blank -%}
              {{ section.settings.empty_cta_label }}
            {%- else -%}
              {{ 'collections.empty_cta' | t }}
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Colección",
  "class": "section-main-collection",
  "settings": [
    { "type": "range", "id": "products_per_page", "min": 8, "max": 48, "step": 4, "label": "Productos por página", "default": 16 },
    { "type": "checkbox", "id": "show_quick_add", "label": "Quick add en tarjetas", "default": true },
    { "type": "text", "id": "empty_cta_label", "label": "Botón colección vacía", "default": "Ver catálogo completo" },
    { "type": "url", "id": "empty_cta_url", "label": "URL colección vacía" }
  ]
}
{% endschema %}
