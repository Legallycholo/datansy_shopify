<section class="gsm-section gsm-testimonials">
  <div class="page-width">
    <div class="gsm-section__header gsm-section__header--center">
      {%- if section.settings.heading != blank -%}
        <h2 class="gsm-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="gsm-section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="gsm-testimonials__scroll" data-testimonials-scroll>
    <div class="gsm-testimonials__track">
      {%- for block in section.blocks -%}
        <div class="gsm-testimonials__card gsm-card" {{ block.shopify_attributes }}>
          <div class="gsm-testimonials__card-header">
            <span class="gsm-testimonials__name">{{ block.settings.name }}</span>
            <span class="gsm-testimonials__verified">Compra Verificada</span>
          </div>
          {%- if block.settings.product != blank -%}
            <p class="gsm-testimonials__product">{{ block.settings.product }}</p>
          {%- endif -%}
          {% render 'gsm-stars', rating: block.settings.rating %}
          {%- if block.settings.quote != blank -%}
            <blockquote class="gsm-testimonials__quote">"{{ block.settings.quote }}"</blockquote>
          {%- endif -%}
        </div>
      {%- endfor -%}
      {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="gsm-testimonials__card gsm-card" aria-hidden="true">
          <div class="gsm-testimonials__card-header">
            <span class="gsm-testimonials__name">{{ block.settings.name }}</span>
            <span class="gsm-testimonials__verified">Compra Verificada</span>
          </div>
          {%- if block.settings.product != blank -%}
            <p class="gsm-testimonials__product">{{ block.settings.product }}</p>
          {%- endif -%}
          {% render 'gsm-stars', rating: block.settings.rating %}
          {%- if block.settings.quote != blank -%}
            <blockquote class="gsm-testimonials__quote">"{{ block.settings.quote }}"</blockquote>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "GSMPRO Testimonios",
  "tag": "section",
  "class": "section-gsm-testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Experiencia GSMPRO" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "Lo que dicen nuestros clientes de Arica a Punta Arenas." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reseña",
      "settings": [
        { "type": "text", "id": "name", "label": "Nombre", "default": "Cliente" },
        { "type": "text", "id": "product", "label": "Producto", "default": "Producto GSMPRO" },
        { "type": "textarea", "id": "quote", "label": "Cita", "default": "Excelente servicio y entrega rápida." },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Estrellas", "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "GSMPRO Testimonios",
      "blocks": [
        { "type": "review", "settings": { "name": "Carlos M.", "product": "iPhone 15 Pro", "quote": "Llegó en 24 horas a Santiago. Impecable." } },
