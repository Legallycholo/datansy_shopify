{%- if section.settings.enabled -%}
<section class="dty-section dty-testimonials">
  <div class="page-width">
    <div class="dty-section__header dty-section__header--center dty-reveal">
      {%- if section.settings.heading != blank -%}
        <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="dty-section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="dty-testimonials__scroll" data-testimonials-scroll>
    <div class="dty-testimonials__track">
      {%- for block in section.blocks -%}
        {% render 'dty-testimonial-card', block: block %}
      {%- endfor -%}
      {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        {% render 'dty-testimonial-card', block: block, decorative: true %}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Datansy Testimonios",
  "tag": "section",
  "class": "section-dty-testimonials",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Mostrar sección", "default": false, "info": "Activa solo cuando tengas reseñas reales de clientes." },
    { "type": "text", "id": "heading", "label": "Título", "default": "Clientes Datansy" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "Compras verificadas de Arica a Punta Arenas." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reseña",
      "settings": [
        { "type": "text", "id": "name", "label": "Nombre", "default": "Cliente" },
        {
          "type": "product",
          "id": "linked_product",
          "label": "Producto vinculado",
          "info": "Al hacer clic, el cliente irá a la página de este producto."
        },
        {
          "type": "text",
          "id": "product",
          "label": "Nombre del producto",
          "default": "Producto Datansy",
          "info": "Opcional. Si está vacío, se usa el título del producto vinculado."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace alternativo",
          "info": "Solo si no hay producto vinculado (ej. colección o página)."
        },
        { "type": "textarea", "id": "quote", "label": "Cita", "default": "Excelente servicio y entrega rápida." },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Estrellas", "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Testimonios",
      "blocks": [
        { "type": "review", "settings": { "name": "Carlos M.", "product": "iPhone 15 Pro", "quote": "Llegó en 24 horas a Santiago. Impecable." } },
        { "type": "review", "settings": { "name": "Valentina R.", "product": "Samsung Galaxy S24", "quote": "El mejor precio que encontré en Chile." } },
        { "type": "review", "settings": { "name": "Diego P.", "product": "Google Pixel 8", "quote": "Atención excelente por WhatsApp." } },
        { "type": "review", "settings": { "name": "Camila S.", "product": "AirPods Pro", "quote": "Producto original con garantía oficial." } },
        { "type": "review", "settings": { "name": "Andrés L.", "product": "Steam Deck OLED", "quote": "Compré desde Concepción, todo perfecto." } },
        { "type": "review", "settings": { "name": "Francisca H.", "product": "MacBook Air M3", "quote": "Envío gratis y embalaje impecable." } },
        { "type": "review", "settings": { "name": "Matías G.", "product": "PlayStation 5", "quote": "Segunda compra, siempre confiable." } },
        { "type": "review", "settings": { "name": "Javiera T.", "product": "DJI Mini 4 Pro", "quote": "Llegó a Punta Arenas sin problemas." } },
        { "type": "review", "settings": { "name": "Rodrigo A.", "product": "RTX 4080 Super", "quote": "Precio increíble vs otras tiendas." } },
        { "type": "review", "settings": { "name": "Constanza V.", "product": "iPad Pro M4", "quote": "Preventa cumplida a tiempo." } },
        { "type": "review", "settings": { "name": "Felipe N.", "product": "Meta Quest 3", "quote": "Recomendado 100%." } },
        { "type": "review", "settings": { "name": "Isidora C.", "product": "Xiaomi 14 Ultra", "quote": "Excelente experiencia de compra." } }
      ]
    }
  ]
}
{% endschema %}
