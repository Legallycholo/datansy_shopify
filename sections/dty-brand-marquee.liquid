{%- assign brands_with_logos = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.settings.logo != blank -%}
    {%- assign brands_with_logos = brands_with_logos | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if brands_with_logos > 0 -%}
<section class="dty-section dty-marquee-section">
  <div class="page-width dty-section__header">
    {%- if section.settings.label != blank -%}
      <span class="dty-section__label">{{ section.settings.label }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="dty-marquee dty-marquee--row-1">
    <div class="dty-marquee__mask dty-marquee__mask--left"></div>
    <div class="dty-marquee__mask dty-marquee__mask--right"></div>
    <div class="dty-marquee__track">
      {%- for block in section.blocks -%}
        {%- if block.settings.logo != blank -%}
        <div class="dty-marquee__logo" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
            {{ block.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy', class: 'dty-marquee__logo-img', alt: block.settings.name }}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
      {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.logo != blank -%}
        <div class="dty-marquee__logo" aria-hidden="true">
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" tabindex="-1">{%- endif -%}
            {{ block.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy', class: 'dty-marquee__logo-img', alt: '' }}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="dty-marquee dty-marquee--row-2">
    <div class="dty-marquee__mask dty-marquee__mask--left"></div>
    <div class="dty-marquee__mask dty-marquee__mask--right"></div>
    <div class="dty-marquee__track dty-marquee__track--reverse">
      {%- for block in section.blocks reversed -%}
        {%- if block.settings.logo != blank -%}
        <div class="dty-marquee__logo" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
            {{ block.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy', class: 'dty-marquee__logo-img', alt: block.settings.name }}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
      {%- for block in section.blocks reversed -%}
        {%- if block.settings.logo != blank -%}
        <div class="dty-marquee__logo" aria-hidden="true">
          {{ block.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy', class: 'dty-marquee__logo-img', alt: '' }}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Datansy Marcas",
  "tag": "section",
  "class": "section-dty-marquee",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Marcas Oficiales" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Solo las Mejores Marcas" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marca",
      "settings": [
        { "type": "text", "id": "name", "label": "Nombre", "default": "Marca" },
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "url", "id": "link", "label": "Enlace" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Marcas",
      "blocks": [
        { "type": "brand", "settings": { "name": "Google" } },
        { "type": "brand", "settings": { "name": "Apple" } },
        { "type": "brand", "settings": { "name": "Samsung" } },
        { "type": "brand", "settings": { "name": "Motorola" } },
        { "type": "brand", "settings": { "name": "Vivo" } },
        { "type": "brand", "settings": { "name": "ZTE" } },
        { "type": "brand", "settings": { "name": "Red Magic" } },
        { "type": "brand", "settings": { "name": "CAT" } },
        { "type": "brand", "settings": { "name": "Valve" } },
        { "type": "brand", "settings": { "name": "Sony" } },
        { "type": "brand", "settings": { "name": "Xbox" } },
        { "type": "brand", "settings": { "name": "Amazon" } },
        { "type": "brand", "settings": { "name": "Meta" } },
        { "type": "brand", "settings": { "name": "Ray-Ban" } },
        { "type": "brand", "settings": { "name": "Oakley" } },
        { "type": "brand", "settings": { "name": "DJI" } },
        { "type": "brand", "settings": { "name": "Hollyland" } },
