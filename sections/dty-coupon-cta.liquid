<section class="dty-section dty-coupon-cta">
  <div class="page-width">
    <div class="dty-coupon-cta__card dty-reveal">
      <div class="dty-coupon-cta__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="dty-coupon-cta__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="dty-coupon-cta__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}

        <div class="dty-coupon-cta__coupon-row">
          {%- assign coupon = section.settings.coupon_code | default: settings.default_coupon_code | default: 'BIENVENIDO10' -%}
          <div class="dty-coupon">
            <span class="dty-coupon__code">{{ coupon }}</span>
            <button
              type="button"
              class="dty-coupon__copy"
              data-coupon-copy
              data-coupon-code="{{ coupon }}"
            >
              Canjear
            </button>
          </div>
        </div>

        {%- if section.settings.urgency_text != blank -%}
          <p class="dty-coupon-cta__urgency">{{ section.settings.urgency_text }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.show_newsletter -%}
        <div class="dty-coupon-cta__form">
          {% form 'customer', class: 'dty-coupon-cta__newsletter' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <label class="visually-hidden" for="CouponEmail-{{ section.id }}">Email</label>
            <input
              id="CouponEmail-{{ section.id }}"
              type="email"
              name="contact[email]"
              placeholder="{{ section.settings.email_placeholder }}"
              required
              autocomplete="email"
              class="dty-coupon-cta__input"
            >
            <button type="submit" class="btn btn--primary">{{ section.settings.submit_label }}</button>
            {%- if form.posted_successfully? -%}
              <p class="dty-coupon-cta__success">{{ section.settings.success_message }}</p>
            {%- endif -%}
          {% endform %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Datansy Cupón CTA",
  "tag": "section",
  "class": "section-dty-coupon",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Primera Compra con Descuento" },
    { "type": "text", "id": "subtext", "label": "Subtexto", "default": "Déjanos tu correo y recibe 10% off con el código BIENVENIDO10." },
    { "type": "text", "id": "coupon_code", "label": "Código cupón", "default": "BIENVENIDO10" },
    { "type": "text", "id": "urgency_text", "label": "Texto urgencia", "default": "Usa el código al finalizar tu compra" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Mostrar formulario email", "default": true },
    { "type": "text", "id": "email_placeholder", "label": "Placeholder email", "default": "tu@email.com" },
    { "type": "text", "id": "submit_label", "label": "Botón suscripción", "default": "Unirme" },
    { "type": "text", "id": "success_message", "label": "Mensaje éxito", "default": "¡Gracias por unirte!" }
  ],
  "presets": [{ "name": "Datansy Cupón CTA" }]
}
{% endschema %}
