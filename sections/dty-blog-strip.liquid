{%- assign blog = blogs[section.settings.blog] -%}
{%- assign blog_articles = blog.articles | default: empty -%}
{%- if blog != blank and blog_articles.size > 0 -%}
<section class="dty-section dty-blog-strip">
  <div class="page-width">
    <div class="dty-section__header dty-section__header--center">
      {%- if section.settings.heading != blank -%}
        <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    <div class="dty-blog-strip__grid">
      {%- for article in blog_articles limit: section.settings.posts_to_show -%}
        <a href="{{ article.url }}" class="dty-blog-strip__card dty-card">
          {%- if article.image -%}
            {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'dty-blog-strip__image', alt: article.title }}
          {%- else -%}
            <div class="placeholder-image dty-blog-strip__image">{{ 'blog.read_more' | t }}</div>
          {%- endif -%}
          <div class="dty-blog-strip__info">
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" class="dty-blog-strip__date">{{ article.published_at | date: '%d/%m/%Y' }}</time>
            <h3 class="dty-blog-strip__title">{{ article.title }}</h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
    {%- if section.settings.view_all_url != blank -%}
      <p class="dty-blog-strip__view-all">
        <a href="{{ section.settings.view_all_url }}">{{ section.settings.view_all_label }}</a>
      </p>
    {%- endif -%}
  </div>
</section>
{%- endif -%}

<style>
  .dty-blog-strip__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 768px) { .dty-blog-strip__grid { grid-template-columns: repeat(3, 1fr); } }
  .dty-blog-strip__card { overflow: hidden; text-decoration: none; color: inherit; padding: 0; }
  .dty-blog-strip__image { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius-xl) var(--radius-xl) 0 0; }
  .dty-blog-strip__info { padding: var(--space-4); }
  .dty-blog-strip__date { font-size: var(--text-xs); color: var(--dty-text-muted); }
  .dty-blog-strip__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; margin: var(--space-2) 0 0; }
  .dty-blog-strip__view-all { text-align: center; margin-top: var(--space-6); }
  .dty-blog-strip__view-all a { color: var(--dty-blue); font-weight: 600; text-decoration: underline; }
</style>

{% schema %}
{
  "name": "Datansy Blog strip",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Datansy News - Tecnología y Noticias" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "posts_to_show", "min": 2, "max": 6, "step": 1, "label": "Artículos", "default": 3 },
    { "type": "text", "id": "view_all_label", "label": "Enlace ver todo", "default": "Ver todas las noticias" },
    { "type": "url", "id": "view_all_url", "label": "URL ver todo" }
  ],
  "presets": [{ "name": "Datansy Blog strip" }]
}
{% endschema %}
