<section class="dty-section dty-featured-collections">
  <div class="page-width">
    <div class="dty-section__header">
      {%- if section.settings.label != blank -%}
        <span class="dty-section__label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="dty-featured-collections__grid">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- assign card_url = nil -%}
        {%- if coll != blank and coll.products_count > 0 -%}
          {%- assign card_url = coll.url -%}
        {%- elsif block.settings.fallback_url != blank -%}
          {%- assign card_url = block.settings.fallback_url -%}
        {%- endif -%}
        {%- if card_url != nil -%}
        {%- liquid
          assign card_image = nil
          assign card_image_alt = block.settings.title | default: coll.title

          if block.settings.image != blank
            assign card_image = block.settings.image
          elsif block.settings.use_collection_image and coll.featured_image
            assign card_image = coll.featured_image
            assign card_image_alt = coll.title
          elsif block.settings.product != blank and block.settings.product.featured_image
            assign card_image = block.settings.product.featured_image
            assign card_image_alt = block.settings.product.title
          elsif coll.products_count > 0
            assign featured_product = coll.products.first
            if featured_product.featured_image
              assign card_image = featured_product.featured_image
              assign card_image_alt = featured_product.title
            endif
          endif

          if card_image == nil and coll.featured_image
            assign card_image = coll.featured_image
            assign card_image_alt = coll.title
          endif
        -%}
        <a href="{{ card_url }}" class="dty-featured-collections__card dty-card" {{ block.shopify_attributes }}>
          <div class="dty-featured-collections__media">
            {%- if card_image -%}
              {{ card_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_image_alt }}
            {%- else -%}
              <div class="placeholder-image">Colección</div>
            {%- endif -%}
          </div>
          <div class="dty-featured-collections__info">
            <h3 class="dty-featured-collections__title">{{ block.settings.title | default: coll.title }}</h3>
            {%- if block.settings.subtitle != blank -%}
              <p class="dty-featured-collections__subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>
        </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Datansy Colecciones",
  "tag": "section",
  "class": "section-dty-featured-collections",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Destacados" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Unidades Limitadas" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Colección",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Colección" },
        { "type": "text", "id": "title", "label": "Título personalizado" },
        { "type": "text", "id": "subtitle", "label": "Subtítulo" },
        {
          "type": "product",
          "id": "product",
          "label": "Producto destacado",
          "info": "Imagen del producto para esta tarjeta. Si no se elige, se usa el primer producto de la colección."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen personalizada",
          "info": "Tiene prioridad sobre el producto y la colección."
        },
        {
          "type": "checkbox",
          "id": "use_collection_image",
          "label": "Usar imagen de la colección",
          "default": false,
          "info": "Muestra la imagen destacada de la colección en lugar de un producto."
        },
        { "type": "url", "id": "fallback_url", "label": "URL alternativa" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Colecciones",
      "blocks": [
        { "type": "collection", "settings": { "title": "Entrega Express", "subtitle": "Stock inmediato" } },
        { "type": "collection", "settings": { "title": "Últimas unidades", "subtitle": "No te quedes sin el tuyo" } },
        { "type": "collection", "settings": { "title": "Outlet", "subtitle": "Precios especiales" } }
      ]
    }
  ]
}
{% endschema %}
