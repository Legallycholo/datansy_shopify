<section class="gsm-special-page page-width">
  <div class="gsm-special-page__card">
    <h1 class="gsm-special-page__title">{{ page.title | default: section.settings.heading }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="gsm-special-page__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    {%- if page.content != blank -%}
      <div class="rte" style="margin-bottom: var(--space-6);">{{ page.content }}</div>
    {%- endif -%}

    <form class="gsm-rastreo-form" action="{{ section.settings.tracking_url | default: 'https://datansy.com/pages/rastrea-tu-pedido' }}" method="get" target="_blank">
      <div class="gsm-form-field">
        <label for="RastreoOrder">{{ 'forms.order_number' | t }}</label>
        <input id="RastreoOrder" type="text" name="order" required placeholder="{{ section.settings.order_placeholder }}">
      </div>
      <div class="gsm-form-field">
        <label for="RastreoEmail">{{ 'forms.email' | t }}</label>
        <input id="RastreoEmail" type="email" name="email" required placeholder="tu@email.com" autocomplete="email">
      </div>
      <button type="submit" class="btn btn--primary" style="width: 100%;">{{ section.settings.submit_label }}</button>
    </form>

    {%- if section.settings.help_text != blank -%}
      <p style="margin-top: var(--space-6); font-size: var(--text-sm); color: var(--gsm-text-muted); text-align: center;">{{ section.settings.help_text }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Página rastreo",
  "class": "section-page-rastreo",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título fallback", "default": "Rastrea tu Pedido" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Ingresa tu número de pedido y email para ver el estado de tu envío." },
    { "type": "text", "id": "order_placeholder", "label": "Placeholder pedido", "default": "Ej: #1234" },
    { "type": "text", "id": "submit_label", "label": "Botón", "default": "Rastrear pedido" },
    { "type": "url", "id": "tracking_url", "label": "URL servicio de rastreo (opcional)" },
    { "type": "text", "id": "help_text", "label": "Texto ayuda", "default": "¿Problemas? Escríbenos a contacto@datansy.com" }
  ]
}
{% endschema %}
