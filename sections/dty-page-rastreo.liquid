<section class="dty-special-page page-width">
  <div class="dty-special-page__card">
    <h1 class="dty-special-page__title">{{ page.title | default: section.settings.heading }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="dty-special-page__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    {%- if page.content != blank -%}
      <div class="rte" style="margin-bottom: var(--space-6);">{{ page.content }}</div>
    {%- endif -%}

    <div class="dty-rastreo-actions">
      <a href="{{ routes.account_url }}" class="btn btn--primary" style="width: 100%; margin-bottom: var(--space-4);">
        {{ section.settings.account_cta_label }}
      </a>

      {%- if section.settings.show_guest_lookup -%}
        <p class="dty-rastreo-actions__hint">{{ section.settings.guest_hint }}</p>
        <a href="{{ section.settings.guest_lookup_url | default: routes.account_login_url }}" class="btn btn--outline" style="width: 100%; border-color: var(--dty-blue); color: var(--dty-blue);">
          {{ section.settings.guest_cta_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.help_text != blank -%}
      <p style="margin-top: var(--space-6); font-size: var(--text-sm); color: var(--dty-text-muted); text-align: center;">
        {{ section.settings.help_text }}
        {%- if section.settings.help_email != blank -%}
          <a href="mailto:{{ section.settings.help_email }}">{{ section.settings.help_email }}</a>
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Página rastreo",
  "class": "section-page-rastreo",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título fallback", "default": "Rastrea tu Pedido" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Consulta el estado de tu pedido desde tu cuenta Datansy o el enlace de seguimiento en tu email de confirmación." },
    { "type": "text", "id": "account_cta_label", "label": "Botón cuenta", "default": "Ver mis pedidos" },
    { "type": "checkbox", "id": "show_guest_lookup", "label": "Mostrar enlace invitado", "default": true },
    { "type": "text", "id": "guest_hint", "label": "Texto invitado", "default": "¿Compraste como invitado? Inicia sesión con el email de tu pedido." },
    { "type": "text", "id": "guest_cta_label", "label": "Botón invitado", "default": "Iniciar sesión" },
    { "type": "url", "id": "guest_lookup_url", "label": "URL inicio de sesión" },
    { "type": "textarea", "id": "help_text", "label": "Texto ayuda", "default": "¿Problemas con tu envío? Escríbenos a " },
    { "type": "text", "id": "help_email", "label": "Email ayuda", "default": "contacto@datansy.com" }
  ]
}
{% endschema %}
