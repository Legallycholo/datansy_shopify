<section class="gsm-customer page-width">
  <div class="gsm-customer__card">
    <h1 class="gsm-customer__title">{{ 'customer.reset_password.title' | t }}</h1>
    <p style="color: var(--gsm-text-muted); margin-bottom: var(--space-6);">{{ 'customer.reset_password.subtext' | t }}</p>

    {% form 'reset_customer_password' %}
      {%- if form.errors -%}
        <div class="gsm-customer__errors">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="gsm-form-field">
        <label for="ResetPassword">{{ 'customer.login.password' | t }}</label>
        <input id="ResetPassword" type="password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div class="gsm-form-field">
        <label for="ResetPasswordConfirm">{{ 'customer.reset_password.confirm' | t }}</label>
        <input id="ResetPasswordConfirm" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary" style="width: 100%;">{{ 'customer.reset_password.submit' | t }}</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "class": "section-main-reset-password",
  "settings": []
}
{% endschema %}
