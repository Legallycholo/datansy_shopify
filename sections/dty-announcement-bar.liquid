{%- if section.settings.enabled and section.blocks.size > 0 -%}
<div class="dty-announcement-bar" id="DtyAnnouncementBar" data-announcement-bar>
  <div class="dty-announcement-bar__track" data-announcement-track>
    {%- for block in section.blocks -%}
      <div
        class="dty-announcement-bar__item{% if forloop.first %} is-active{% endif %}"
        data-announcement-item
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.url != blank -%}
          <a href="{{ block.settings.url }}" class="dty-announcement-bar__link">
            {%- if block.settings.icon != blank -%}
              <span class="material-symbols-outlined dty-announcement-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {%- endif -%}
            {{ block.settings.text }}
          </a>
        {%- else -%}
          <span>
            {%- if block.settings.icon != blank -%}
              <span class="material-symbols-outlined dty-announcement-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {%- endif -%}
            {{ block.settings.text }}
          </span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  <button
    type="button"
    class="dty-announcement-bar__close"
    data-announcement-close
    aria-label="Cerrar barra"
  >
    <span class="material-symbols-outlined" aria-hidden="true">close</span>
  </button>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Barra de anuncio",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Mostrar barra",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Velocidad de rotación (segundos)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Mensaje",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Mensaje",
          "default": "🚀 Envío gratis a todo Chile en compras sobre $50.000"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono Material (opcional)",
          "info": "Nombre del ícono de Material Symbols, ej: local_shipping. Dejar en campaign para ocultar."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Enlace (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de anuncio",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "🚀 Envío gratis a todo Chile en compras sobre $50.000",
            "url": "/collections/coleccion-principal"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "🎁 Clientes nuevos: 10% off con el código BIENVENIDO10",
            "url": "/collections/coleccion-principal"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "✅ 30 días de garantía en todos los productos",
            "url": "/pages/about-us"
          }
        }
      ]
    }
  ]
}
{% endschema %}
