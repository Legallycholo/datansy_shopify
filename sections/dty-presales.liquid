<section class="dty-section dty-presales">
  <div class="page-width">
    <div class="dty-section__header">
      {%- if section.settings.label != blank -%}
        <span class="dty-section__label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="dty-presales__benefits">
      {%- for block in section.blocks -%}
        {%- if block.type == 'benefit' -%}
          <div class="dty-presales__benefit dty-card" {{ block.shopify_attributes }}>
            <span class="material-symbols-outlined dty-presales__benefit-icon" aria-hidden="true">{{ block.settings.icon | default: 'verified' }}</span>
            <h3 class="dty-presales__benefit-title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="dty-presales__benefit-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="dty-presales__products">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_teaser' and block.settings.url != blank -%}
          <a href="{{ block.settings.url }}" class="dty-presales__product dty-card" {{ block.shopify_attributes }}>
            <div class="dty-presales__product-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                <div class="placeholder-image placeholder-image--square">IMG</div>
              {%- endif -%}
              {%- if block.settings.status != blank -%}
                <span class="dty-presales__status dty-presales__status--{{ block.settings.status | handle }}">{{ block.settings.status }}</span>
              {%- endif -%}
            </div>
            <h3 class="dty-presales__product-title">{{ block.settings.title }}</h3>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_url != blank -%}
      <div class="dty-presales__cta-wrap">
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Datansy Preventas",
  "tag": "section",
  "class": "section-dty-presales",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Preventas VIP" },
    { "type": "text", "id": "heading", "label": "Título", "default": "El Futuro Llega Primero Aquí." },
    { "type": "text", "id": "cta_label", "label": "CTA", "default": "Ver Colección Preventa" },
    { "type": "url", "id": "cta_url", "label": "URL CTA" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "icon", "label": "Icono", "default": "verified" },
        { "type": "text", "id": "title", "label": "Título", "default": "Beneficio" },
        { "type": "text", "id": "text", "label": "Descripción" }
      ]
    },
    {
      "type": "product_teaser",
      "name": "Producto teaser",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "title", "label": "Título", "default": "Producto" },
        {
          "type": "select",
          "id": "status",
          "label": "Estado",
          "options": [
            { "value": "CONFIRMADO", "label": "CONFIRMADO" },
            { "value": "PRÓXIMAMENTE", "label": "PRÓXIMAMENTE" },
            { "value": "RUMOR", "label": "RUMOR" },
            { "value": "ESPERA", "label": "ESPERA" },
            { "value": "PROTOTIPO", "label": "PROTOTIPO" }
          ],
          "default": "PRÓXIMAMENTE"
        },
        { "type": "url", "id": "url", "label": "Enlace" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Preventas",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "sell", "title": "Precio Especial", "text": "Accede al mejor precio de preventa." } },
        { "type": "benefit", "settings": { "icon": "priority_high", "title": "Prioridad Total", "text": "Sé de los primeros en recibirlo." } },
        { "type": "benefit", "settings": { "icon": "inventory", "title": "Stock Asegurado", "text": "Reserva garantizada desde el día uno." } },
        { "type": "product_teaser", "settings": { "title": "S26 Ultra", "status": "RUMOR" } },
        { "type": "product_teaser", "settings": { "title": "Steam Deck Machine", "status": "PROTOTIPO" } },
        { "type": "product_teaser", "settings": { "title": "Poco F8", "status": "PRÓXIMAMENTE" } },
        { "type": "product_teaser", "settings": { "title": "Pixel 10a", "status": "CONFIRMADO" } },
        { "type": "product_teaser", "settings": { "title": "RTX 5090", "status": "ESPERA" } },
        { "type": "product_teaser", "settings": { "title": "iPad Pro M5", "status": "RUMOR" } }
      ]
    }
  ]
}
{% endschema %}
