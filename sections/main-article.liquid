<article class="dty-article page-width">
  <a href="{{ blog.url }}" class="dty-article__back">
    <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
    {{ 'blog.back_to_blog' | t }}
  </a>

  {%- if article.image -%}
    {{ article.image | image_url: width: 1200 | image_tag: loading: 'eager', class: 'dty-article__image', alt: article.title }}
  {%- else -%}
    <div class="placeholder-image dty-article__image" style="aspect-ratio: 16/9; border-radius: var(--radius-2xl);">Article image placeholder</div>
  {%- endif -%}

  <div class="dty-article__meta">
    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%d/%m/%Y' }}</time>
    {%- if article.author != blank -%}
      <span>{{ 'blog.author' | t: author: article.author }}</span>
    {%- endif -%}
    {%- if blog.title != blank -%}
      <span>{{ blog.title }}</span>
    {%- endif -%}
  </div>

  <h1 class="dty-article__title">{{ article.title }}</h1>
  <div class="dty-article__content rte">{{ article.content }}</div>
</article>

{% schema %}
{
  "name": "Artículo",
  "class": "section-main-article",
  "settings": []
}
{% endschema %}
