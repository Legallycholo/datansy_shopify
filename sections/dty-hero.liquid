{%- comment -%} Hero section — animated slogan rotation + floating category showcase {%- endcomment -%}

<section class="dty-hero" data-hero-rotation data-slogan-sets='[
  {%- assign slogan_sets = section.blocks | where: "type", "slogan_set" -%}
  {%- for block in slogan_sets -%}
    ["{{ block.settings.line_1 | escape }}","{{ block.settings.line_2 | escape }}","{{ block.settings.line_3 | escape }}"]{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]'>
  <div class="dty-hero__bg" aria-hidden="true">
    <div class="dty-hero__circle dty-hero__circle--1"></div>
    <div class="dty-hero__circle dty-hero__circle--2"></div>
    <div class="dty-hero__circle dty-hero__circle--3"></div>
    <div class="dty-hero__gradient"></div>
    <div class="dty-hero__dots" aria-hidden="true"></div>
  </div>

  <div class="page-width dty-hero__outer">
    <div class="dty-hero__inner">

      {%- comment -%} Left — text content {%- endcomment -%}
      <div class="dty-hero__left">
        {%- if section.settings.badge != blank -%}
          <span class="dty-badge dty-hero__badge">
            <span class="dty-hero__badge-dot"></span>
            {{ section.settings.badge }}
          </span>
        {%- endif -%}

        {%- assign first_set = slogan_sets | first -%}
        <h1 class="dty-hero__headline">
          <span class="dty-hero__headline-line" data-hero-line>{{ first_set.settings.line_1 | default: section.settings.fallback_line_1 }}</span>
          <span class="dty-hero__headline-line" data-hero-line>{{ first_set.settings.line_2 | default: section.settings.fallback_line_2 }}</span>
          <span class="dty-hero__headline-line dty-hero__headline-line--accent" data-hero-line>{{ first_set.settings.line_3 | default: section.settings.fallback_line_3 }}</span>
        </h1>

        {%- if section.settings.subtext != blank -%}
          <p class="dty-hero__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}

        <div class="dty-hero__actions">
          {%- if section.settings.cta_catalog_url != blank -%}
            <a href="{{ section.settings.cta_catalog_url }}" class="btn btn--primary dty-hero__cta-primary">
              <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
              {{ section.settings.cta_catalog_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.cta_flash_url != blank -%}
            <a href="{{ section.settings.cta_flash_url }}" class="btn btn--accent dty-hero__cta-secondary">
              <span class="material-symbols-outlined" aria-hidden="true">bolt</span>
              {{ section.settings.cta_flash_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.settings.show_trust_row -%}
          <div class="dty-hero__trust">
            <span class="dty-hero__trust-text">{{ section.settings.trust_text }}</span>
          </div>
        {%- endif -%}

        <div class="dty-hero__stats">
          <div class="dty-hero__stat">
            <span class="dty-hero__stat-number">{{ section.settings.stat_1_number }}</span>
            <span class="dty-hero__stat-label">{{ section.settings.stat_1_label }}</span>
          </div>
          <div class="dty-hero__stat-divider"></div>
          <div class="dty-hero__stat">
            <span class="dty-hero__stat-number">{{ section.settings.stat_2_number }}</span>
            <span class="dty-hero__stat-label">{{ section.settings.stat_2_label }}</span>
          </div>
          <div class="dty-hero__stat-divider"></div>
          <div class="dty-hero__stat">
            <span class="dty-hero__stat-number">{{ section.settings.stat_3_number }}</span>
            <span class="dty-hero__stat-label">{{ section.settings.stat_3_label }}</span>
          </div>
        </div>
      </div>

      {%- comment -%} Right — floating category showcase {%- endcomment -%}
      {%- liquid
        assign catalog = collections['coleccion-principal']
        assign fallback_url = catalog.url | default: routes.all_products_collection_url
        assign audio_url = collections['audio'].url | default: fallback_url
        if collections['audio'].products_count == 0
          assign audio_url = fallback_url
        endif
        assign watches_url = collections['smartwatches'].url | default: fallback_url
        if collections['smartwatches'].products_count == 0
          assign watches_url = fallback_url
        endif
        assign phones_url = collections['celulares'].url | default: fallback_url
        if collections['celulares'].products_count == 0
          assign phones_url = fallback_url
        endif
        assign offers_url = collections['ofertas'].url | default: fallback_url
        if collections['ofertas'].products_count == 0
          assign offers_url = fallback_url
        endif
      -%}
      <div class="dty-hero__right" aria-hidden="true">
        <div class="dty-hero__cards-grid">
          <a href="{{ audio_url }}" class="dty-hero__card dty-hero__card--delay-0" tabindex="-1">
            <div class="dty-hero__card-icon dty-hero__card-icon--blue">
              <span class="material-symbols-outlined">headphones</span>
            </div>
            <span class="dty-hero__card-label">Audio &amp;<br>Headphones</span>
          </a>
          <a href="{{ watches_url }}" class="dty-hero__card dty-hero__card--delay-1" tabindex="-1">
            <div class="dty-hero__card-icon dty-hero__card-icon--indigo">
              <span class="material-symbols-outlined">watch</span>
            </div>
            <span class="dty-hero__card-label">Smartwatches</span>
          </a>
          <a href="{{ phones_url }}" class="dty-hero__card dty-hero__card--delay-2" tabindex="-1">
            <div class="dty-hero__card-icon dty-hero__card-icon--blue">
              <span class="material-symbols-outlined">smartphone</span>
            </div>
            <span class="dty-hero__card-label">Celulares</span>
          </a>
          <a href="{{ fallback_url }}" class="dty-hero__card dty-hero__card--delay-3" tabindex="-1">
            <div class="dty-hero__card-icon dty-hero__card-icon--indigo">
              <span class="material-symbols-outlined">laptop_mac</span>
            </div>
            <span class="dty-hero__card-label">Computación</span>
          </a>
          <a href="{{ fallback_url }}" class="dty-hero__card dty-hero__card--delay-4" tabindex="-1">
            <div class="dty-hero__card-icon dty-hero__card-icon--yellow">
              <span class="material-symbols-outlined">sports_esports</span>
            </div>
            <span class="dty-hero__card-label">Gaming</span>
          </a>
          <a href="{{ offers_url }}" class="dty-hero__card dty-hero__card--delay-5" tabindex="-1">
            <div class="dty-hero__card-icon dty-hero__card-icon--sale">
              <span class="material-symbols-outlined">local_offer</span>
            </div>
            <span class="dty-hero__card-label">Ofertas<br>Flash</span>
          </a>
        </div>

        <div class="dty-hero__delivery-badge">
          <span class="material-symbols-outlined">local_shipping</span>
          <div>
            <strong>Envío gratis</strong>
            <span>en compras sobre $50.000</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Datansy Hero",
  "tag": "section",
  "class": "section-dty-hero",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Tecnología Premium" },
    { "type": "text", "id": "fallback_line_1", "label": "Línea 1 (fallback)", "default": "Marcas Globales" },
    { "type": "text", "id": "fallback_line_2", "label": "Línea 2 (fallback)", "default": "Precio Directo" },
    { "type": "text", "id": "fallback_line_3", "label": "Línea 3 (fallback)", "default": "En Chile" },
    { "type": "textarea", "id": "subtext", "label": "Subtexto", "default": "Envío gratis sobre $50.000. 30 días de garantía. 10% off con BIENVENIDO10." },
    { "type": "text", "id": "cta_catalog_label", "label": "CTA catálogo", "default": "Ver Catálogo" },
    { "type": "url", "id": "cta_catalog_url", "label": "URL catálogo" },
    { "type": "text", "id": "cta_flash_label", "label": "CTA ofertas", "default": "Ofertas Flash" },
    { "type": "url", "id": "cta_flash_url", "label": "URL ofertas" },
    { "type": "checkbox", "id": "show_trust_row", "label": "Mostrar fila de confianza", "default": true },
    { "type": "text", "id": "trust_text", "label": "Texto confianza", "default": "+5.000 clientes en Chile" },
    { "type": "header", "content": "Stat badges" },
    { "type": "text", "id": "stat_1_number", "label": "Stat 1 número", "default": "30" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 etiqueta", "default": "Días de Garantía" },
    { "type": "text", "id": "stat_2_number", "label": "Stat 2 número", "default": "10%" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 etiqueta", "default": "Off con BIENVENIDO10" },
    { "type": "text", "id": "stat_3_number", "label": "Stat 3 número", "default": "Gratis" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 etiqueta", "default": "Envío +$50.000" }
  ],
  "blocks": [
    {
      "type": "slogan_set",
      "name": "Set de slogans",
      "settings": [
        { "type": "text", "id": "line_1", "label": "Línea 1", "default": "Marcas Globales" },
        { "type": "text", "id": "line_2", "label": "Línea 2", "default": "Precio Directo" },
        { "type": "text", "id": "line_3", "label": "Línea 3", "default": "En Chile" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Hero",
      "blocks": [
        { "type": "slogan_set", "settings": { "line_1": "Marcas Globales", "line_2": "Precio Directo", "line_3": "En Chile" } },
        { "type": "slogan_set", "settings": { "line_1": "Importación Oficial", "line_2": "Sin Intermediarios", "line_3": "Con Garantía" } },
        { "type": "slogan_set", "settings": { "line_1": "Tech de Primera", "line_2": "Entrega a Todo", "line_3": "Chile" } }
      ]
    }
  ]
}
{% endschema %}
