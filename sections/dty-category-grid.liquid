<section class="dty-section dty-categories">
  <div class="page-width">
    <div class="dty-section__header dty-categories__header">
      <div>
        {%- if section.settings.label != blank -%}
          <span class="dty-section__label">{{ section.settings.label }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="dty-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.catalog_url != blank -%}
        <a href="{{ section.settings.catalog_url }}" class="dty-categories__catalog-link">
          {{ section.settings.catalog_label }}
          <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
        </a>
      {%- endif -%}
    </div>

    <div class="dty-categories__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url }}" class="dty-categories__tile" {{ block.shopify_attributes }}>
          <div class="dty-categories__icon-wrap">
            <span class="material-symbols-outlined dty-categories__icon" aria-hidden="true">{{ block.settings.icon | default: 'devices' }}</span>
          </div>
          <span class="dty-categories__name">{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Datansy Categorías",
  "tag": "section",
  "class": "section-dty-categories",
  "settings": [
    { "type": "text", "id": "label", "label": "Etiqueta", "default": "Categorías Elite" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Explora por Categoría" },
    { "type": "text", "id": "catalog_label", "label": "Enlace catálogo", "default": "Ver catálogo completo" },
    { "type": "url", "id": "catalog_url", "label": "URL catálogo" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Categoría" },
        { "type": "text", "id": "icon", "label": "Icono Material", "default": "devices" },
        { "type": "url", "id": "url", "label": "URL colección" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Datansy Categorías",
      "blocks": [
        { "type": "category", "settings": { "title": "Celulares", "icon": "smartphone", "url": "/collections/coleccion-principal" } },
        { "type": "category", "settings": { "title": "Audio", "icon": "headphones", "url": "/collections/coleccion-principal" } },
        { "type": "category", "settings": { "title": "Computación", "icon": "laptop_mac", "url": "/collections/coleccion-principal" } },
        { "type": "category", "settings": { "title": "Wearables", "icon": "watch", "url": "/collections/coleccion-principal" } },
        { "type": "category", "settings": { "title": "Consolas", "icon": "sports_esports", "url": "/collections/coleccion-principal" } },
        { "type": "category", "settings": { "title": "Fotografía", "icon": "photo_camera", "url": "/collections/coleccion-principal" } }
      ]
    }
  ]
}
{% endschema %}
