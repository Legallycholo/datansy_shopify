[
  {
    "name": "theme_info",
    "theme_name": "Datansy",
    "theme_version": "1.0.0",
    "theme_author": "Datansy",
    "theme_documentation_url": "https://datansy.com/",
    "theme_support_url": "https://datansy.com/pages/contact-us"
  },
  {
    "name": "Colores",
    "settings": [
      {
        "type": "header",
        "content": "Paleta Datansy — Warm Premium"
      },
      {
        "type": "color",
        "id": "color_header_bg",
        "label": "Fondo header (stone black)",
        "default": "#1C1917"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Color primario (burnt orange)",
        "default": "#C2410C"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Color secundario (ámbar oscuro)",
        "default": "#92400E"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Color acento (oro ámbar)",
        "default": "#F59E0B"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Fondo de página",
        "default": "#FAFAF9"
      },
      {
        "type": "color",
        "id": "color_background_secondary",
        "label": "Fondo secundario (stone)",
        "default": "#F5F5F4"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Texto principal",
        "default": "#1C1917"
      },
      {
        "type": "color",
        "id": "color_sale",
        "label": "Precio oferta",
        "default": "#B91C1C"
      }
    ]
  },
  {
    "name": "Tipografía",
    "settings": [
      {
        "type": "paragraph",
        "content": "Fuentes: Syne (títulos) y DM Sans (cuerpo). Configuradas en theme.liquid."
      },
      {
        "type": "range",
        "id": "body_font_size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "label": "Tamaño base de texto",
        "default": 16
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Header fijo al hacer scroll",
        "default": false
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Ancho del logo",
        "default": 160
      }
    ]
  },
  {
    "name": "Carrito y promociones",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Tipo de carrito",
        "options": [
          { "value": "drawer", "label": "Panel lateral (drawer)" },
          { "value": "page", "label": "Página de carrito" },
          { "value": "message", "label": "Mensaje / notificación" }
        ],
        "default": "drawer"
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Umbral envío gratis (CLP)",
        "default": 50000
      },
      {
        "type": "text",
        "id": "default_coupon_code",
        "label": "Código de cupón predeterminado",
        "default": "BIENVENIDO10"
      }
    ]
  },
  {
    "name": "Mercados y moneda",
    "settings": [
      {
        "type": "paragraph",
        "content": "Formato CLP recomendado en Admin → Configuración → Detalles de la tienda → Formato de moneda: ${{amount_no_decimals}}"
      },
      {
        "type": "checkbox",
        "id": "show_currency_code",
        "label": "Mostrar código ISO junto al precio",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "localization_auto_submit",
        "label": "Cambiar país al seleccionar (auto-enviar)",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "markets_enable_hreflang",
        "label": "Emitir etiquetas hreflang",
        "default": true
      },
      {
        "type": "header",
        "content": "URLs de mercado (hreflang fallback)"
      },
      {
        "type": "paragraph",
        "content": "Usar cuando Markets no expone root_url (p. ej. dominios Datansy por país). Sin barra final."
      },
      { "type": "url", "id": "market_url_cl", "label": "Chile (CL)" },
      { "type": "url", "id": "market_url_ar", "label": "Argentina (AR)" },
      { "type": "url", "id": "market_url_pe", "label": "Perú (PE)" },
      { "type": "url", "id": "market_url_co", "label": "Colombia (CO)" },
      { "type": "url", "id": "market_url_mx", "label": "México (MX)" },
      { "type": "url", "id": "market_url_us", "label": "Estados Unidos (US)" },
      { "type": "url", "id": "market_url_br", "label": "Brasil (BR)" }
    ]
  },
  {
    "name": "SEO y analytics",
    "settings": [
      {
        "type": "image_picker",
        "id": "seo_default_image",
        "label": "Imagen Open Graph predeterminada",
        "info": "Usada cuando la página no tiene imagen propia (1200×630 recomendado)."
      },
      {
        "type": "text",
        "id": "twitter_handle",
        "label": "Usuario de Twitter/X (sin @)",
        "info": "Opcional — para twitter:site"
      },
      {
        "type": "text",
        "id": "gtm_container_id",
        "label": "Google Tag Manager ID",
        "info": "Ej: GTM-XXXXXXX. Dejar vacío para desactivar."
      },
      {
        "type": "text",
        "id": "google_site_verification",
        "label": "Google Search Console verification",
        "info": "Contenido del meta google-site-verification"
      },
      {
        "type": "text",
        "id": "facebook_domain_verification",
        "label": "Facebook domain verification",
        "info": "Contenido del meta facebook-domain-verification"
      },
      {
        "type": "text",
        "id": "fb_pixel_id",
        "label": "Facebook Pixel ID",
        "info": "Ej: 123456789012345. Activa PageView, ViewContent, y Search automáticamente. AddToCart y Purchase se disparan por eventos del carrito."
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  }
]
