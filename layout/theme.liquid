<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_header_bg }}">
  <link rel="canonical" href="{{ canonical_url }}">
  {% render 'dty-hreflang' %}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/png" href="{{ 'datansy-favicon-black.png' | asset_url }}" sizes="32x32">
    <link rel="icon" type="image/png" href="{{ 'datansy-favicon-white.png' | asset_url }}" sizes="32x32" media="(prefers-color-scheme: dark)">
    <link rel="apple-touch-icon" href="{{ 'datansy-favicon-black.png' | asset_url }}">
  {%- endif -%}

  <title>{%- if template.name == 'index' -%}{{ shop.name }}{%- else -%}
    {{ page_title }}
    {%- if current_tags -%}
      {%- assign tag_list = current_tags | join: ', ' -%}
      &ndash; {{ 'general.tagged' | t: tags: tag_list }}
    {%- endif -%}
    {%- if current_page != 1 %} &ndash; {{ 'general.page' | t: page: current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  {%- endif -%}</title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {% render 'dty-social-meta' %}
  {% render 'dty-jsonld' %}
  {% render 'dty-gtm-head' %}
  {% render 'dty-fb-pixel' %}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@600;700&display=swap" rel="stylesheet"></noscript>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet"></noscript>

  {%- if template.name == 'product' and product.featured_media -%}
    <link
      rel="preload"
      as="image"
      href="{{ product.featured_media | image_url: width: 800 }}"
      imagesrcset="{{ product.featured_media | image_url: width: 400 }} 400w, {{ product.featured_media | image_url: width: 800 }} 800w, {{ product.featured_media | image_url: width: 1200 }} 1200w"
      imagesizes="(min-width: 1024px) 44vw, 100vw"
      fetchpriority="high"
    >
  {%- endif -%}

  {{ 'dty-base.css' | asset_url | stylesheet_tag }}
  {{ 'dty-header.css' | asset_url | stylesheet_tag }}
  {{ 'dty-footer.css' | asset_url | stylesheet_tag }}
  {{ 'bodegas.css' | asset_url | stylesheet_tag }}

  {%- if template.name == 'index' or template.name == 'collection' or template.name == 'search' or template.name == 'list-collections' or template.name == 'product' -%}
    {{ 'dty-catalog.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if template.name == 'index' -%}
    {{ 'dty-home.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if template.name == 'product' -%}
    {{ 'dty-product.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if template.name == 'cart' or template.name == 'page' or template.name == 'blog' or template.name == 'article' or template.name == '404' or template.directory == 'customers' -%}
    {{ 'dty-pages.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  <style>
    :root {
      --dty-dark: {{ settings.color_header_bg }};
      --dty-blue: {{ settings.color_primary }};
      --dty-indigo: {{ settings.color_secondary }};
      --dty-yellow: {{ settings.color_accent }};
      --dty-gray: {{ settings.color_background_secondary }};
      --dty-surface: {{ settings.color_background }};
      --dty-text: {{ settings.color_text }};
      --dty-sale: {{ settings.color_sale }};
      /* RGB components recomputed from settings so translucent overlays/shadows track admin colors */
      --dty-primary-rgb: {{ settings.color_primary | color_extract: 'red' }}, {{ settings.color_primary | color_extract: 'green' }}, {{ settings.color_primary | color_extract: 'blue' }};
      --dty-dark-rgb: {{ settings.color_header_bg | color_extract: 'red' }}, {{ settings.color_header_bg | color_extract: 'green' }}, {{ settings.color_header_bg | color_extract: 'blue' }};
      --dty-accent-rgb: {{ settings.color_accent | color_extract: 'red' }}, {{ settings.color_accent | color_extract: 'green' }}, {{ settings.color_accent | color_extract: 'blue' }};
      --dty-free-shipping-threshold: {{ settings.free_shipping_threshold }};
      --dty-coupon-code: '{{ settings.default_coupon_code }}';
      --logo-width: {{ settings.logo_width | default: 160 }}px;
    }
  </style>

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.dtySettings = {
      freeShippingThreshold: {{ settings.free_shipping_threshold | default: 50000 }},
      couponCode: {{ settings.default_coupon_code | default: 'BIENVENIDO10' | json }},
      cartType: {{ settings.cart_type | default: 'drawer' | json }},
      localizationAutoSubmit: {{ settings.localization_auto_submit | default: true | json }},
      routes: {
        cartUrl: {{ routes.cart_url | json }},
        cartAddUrl: {{ routes.cart_add_url | append: '.js' | json }},
        cartChangeUrl: {{ routes.cart_change_url | append: '.js' | json }},
        predictiveSearchUrl: {{ routes.predictive_search_url | json }},
        allProductsCollectionUrl: {{ routes.all_products_collection_url | json }}
      },
      strings: {
        freeShippingRemaining: {{ 'cart.free_shipping_remaining' | t | json }},
        freeShippingAchieved: {{ 'cart.free_shipping_achieved' | t | json }},
        cartEmpty: {{ 'cart.empty' | t | json }},
        cartEmptyCta: {{ 'cart.empty_cta' | t | json }},
        cartViewCart: {{ 'cart.view_cart' | t | json }},
        cartCheckout: {{ 'cart.checkout' | t | json }},
        couponCopied: {{ 'general.coupon_copied' | t | json }},
        addToCart: {{ 'products.add_to_cart' | t | json }},
        soldOut: {{ 'products.sold_out' | t | json }},
        warehouseInStock: {{ 'products.warehouse_in_stock' | t | json }},
        warehouseAvailable: {{ 'products.warehouse_available' | t | json }},
        loading: {{ 'general.loading' | t | json }},
        remove: {{ 'cart.remove' | t | json }}
      }
    };
  </script>
</head>

<body class="template-{{ template.name | handle }}{% if settings.sticky_header %} header-sticky{% endif %}">
  {% render 'dty-gtm-body' %}
  <a class="skip-to-content visually-hidden" href="#MainContent">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% sections 'header-group' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {% render 'dty-exit-popup' %}

  <button type="button" class="dty-back-to-top" id="DtyBackToTop" aria-label="{{ 'accessibility.back_to_top' | t | default: 'Volver al inicio' }}">
    <span class="material-symbols-outlined" aria-hidden="true">arrow_upward</span>
  </button>

  <script src="{{ 'dty-header.js' | asset_url }}" defer></script>
  <script src="{{ 'dty-markets.js' | asset_url }}" defer></script>
  <script src="{{ 'dty-footer.js' | asset_url }}" defer></script>
  {%- if template.name == 'index' or template.name == 'collection' or template.name == 'search' or template.name == 'list-collections' or template.name == 'product' -%}
    <script src="{{ 'dty-catalog.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if template.name == 'index' -%}
    <script src="{{ 'dty-home.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if template.name == 'product' -%}
    <script src="{{ 'dty-product.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if template.name == 'cart' -%}
    <script src="{{ 'dty-cart-page.js' | asset_url }}" defer></script>
  {%- endif -%}
</body>
</html>
