{% doc %}
  Datansy wordmark with correct contrast for the surface behind it.
  Logo 1 (dark ink) → light/white backgrounds.
  Logo 2 (light ink) → dark/black backgrounds.

  @param {string} background - 'light' or 'dark' (required)
  @param {string} [class] - CSS class for the img or text element
  @param {string} [link_class] - CSS class for the optional link wrapper
  @param {string} [loading] - 'eager' or 'lazy' (default lazy)
  @param {boolean} [link] - Wrap in homepage link (default true)
  @param {image} [image] - Optional Shopify image override from theme settings
  @param {number} [width] - Display width in px
{% enddoc %}

{%- liquid
  assign logo_width = width | default: settings.logo_width | default: 160
  assign logo_loading = loading | default: 'lazy'
  assign logo_class = class | default: 'dty-logo'
  assign logo_link_class = link_class | default: 'dty-logo-link'
  assign logo_image = image | default: settings.logo
  assign wrap_link = link
  if wrap_link == nil
    assign wrap_link = true
  endif
-%}

{%- if wrap_link -%}
  <a href="{{ routes.root_url }}" class="{{ logo_link_class }}" aria-label="{{ shop.name | escape }}">
{%- endif -%}

{%- if logo_image != blank -%}
  {{
    logo_image
    | image_url: width: 400
    | image_tag:
      class: logo_class,
      widths: '160, 240, 320, 400',
      alt: shop.name,
      width: logo_width,
      loading: logo_loading
  }}
{%- else -%}
  <span class="dty-logo-text dty-logo-text--{{ background }} {{ logo_class }}" aria-hidden="true">
    {{ shop.name }}
  </span>
{%- endif -%}

{%- if wrap_link -%}
  </a>
{%- endif -%}
