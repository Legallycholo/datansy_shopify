{% doc %}
  Datansy product card for grids and sliders.
  Includes Refresh-compatible classes for Vitals collection review stars.
  @param {object} product - Shopify product
  @param {boolean} [show_quick_add] - Show quick add button
  @param {string} [class] - Extra CSS class
{% enddoc %}

{%- liquid
  assign show_quick_add = show_quick_add | default: true
  assign card_variant = product.selected_or_first_available_variant
  assign can_purchase = false

  for variant in product.variants
    if variant.available or variant.inventory_policy == 'continue'
      assign card_variant = variant
      assign can_purchase = true
      break
    endif
  endfor

  assign on_sale = false
  if card_variant.compare_at_price > card_variant.price
    assign on_sale = true
    assign savings = card_variant.compare_at_price | minus: card_variant.price
  endif
-%}

<article class="dty-product-card product-card-wrapper card card--standard{% if class %} {{ class }}{% endif %}">
  <div class="card__inner">
    <a href="{{ product.url }}" class="dty-product-card__media-link full-unstyled-link" tabindex="-1" aria-hidden="true">
      <div class="card__media dty-product-card__media">
        {%- if product.featured_media -%}
          {{
            product.featured_media
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              decoding: 'async',
              class: 'dty-product-card__image',
              widths: '200, 300, 400, 600',
              sizes: '(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw',
              alt: product.featured_media.alt | default: product.title
          }}
        {%- else -%}
          <div class="placeholder-image placeholder-image--square dty-product-card__placeholder">IMG</div>
        {%- endif -%}
        {%- if on_sale -%}
          <span class="dty-product-card__badge dty-product-card__badge--sale">
            {{ 'products.save' | t }} {% render 'dty-money', amount: savings %}
          </span>
        {%- endif -%}
      </div>
    </a>
  </div>

  <div class="card__content dty-product-card__info">
    <div class="card__information">
      {%- if product.vendor != blank -%}
        <p class="dty-product-card__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h3 class="card__heading dty-product-card__title">
        <a href="{{ product.url }}" class="full-unstyled-link">{{ product.title }}</a>
      </h3>

      <div class="dty-product-card__price-row">
        {%- if product.price_varies -%}
          <span class="dty-product-card__price">
            {{ 'products.from_price' | t }} {% render 'dty-money', amount: product.price_min %}
          </span>
        {%- else -%}
          <span class="dty-product-card__price{% if on_sale %} dty-product-card__price--sale{% endif %}">{%- render 'dty-money', amount: product.price -%}</span>
          {%- if on_sale -%}
            <s class="dty-product-card__compare">{%- render 'dty-money', amount: product.compare_at_price -%}</s>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- comment -%} Vitals injects collection review stars after .card__heading {%- endcomment -%}

      <div class="dty-product-card__actions">
        {%- if show_quick_add and can_purchase -%}
          <form method="post" action="{{ routes.cart_add_url }}" class="dty-product-card__form" data-product-card-form>
            <input type="hidden" name="id" value="{{ card_variant.id }}">
            <button type="submit" class="btn btn--primary dty-product-card__atc" name="add">
              {{ 'products.add_to_cart' | t }}
            </button>
          </form>
        {%- elsif show_quick_add -%}
          <span class="btn dty-product-card__sold-out">{{ 'products.sold_out' | t }}</span>
        {%- else -%}
          <a href="{{ product.url }}" class="btn btn--primary dty-product-card__view">{{ 'products.view_product' | t }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</article>
