{% doc %}
  Mobile slide-out navigation with 3-level drill-down panels.
  @param {object} section - Header section object with menu blocks
{% enddoc %}

<nav id="DtyMobileNav" class="dty-mobile-nav" aria-label="{{ 'general.menu' | t }}">
  <div class="dty-mobile-nav__header">
    <div class="dty-mobile-nav__brand">
      {% render 'dty-logo',
        background: 'dark',
        class: 'dty-mobile-nav__logo-img',
        link_class: 'dty-mobile-nav__logo-link',
        width: settings.logo_width,
        loading: 'lazy',
        link: true
      %}
    </div>
    <button type="button" class="dty-mobile-nav__close" data-mobile-nav-close aria-label="{{ 'accessibility.close_menu' | t }}">
      <span class="material-symbols-outlined" aria-hidden="true">close</span>
    </button>
  </div>

  <div class="dty-mobile-nav__panels">
    {%- comment -%} Root panel {%- endcomment -%}
    <div class="dty-mobile-nav__panel is-active" data-mobile-panel="root">
      <ul class="dty-mobile-nav__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_item' -%}
            {%- liquid
              assign show_menu_item = true
              if block.settings.url != blank and block.settings.url contains '/collections/'
                assign menu_handle = block.settings.url | split: '/collections/' | last | split: '?' | first | split: '/' | first
                assign menu_collection = collections[menu_handle]
                if menu_collection != blank and menu_collection.products_count == 0
                  assign show_menu_item = false
                endif
              endif
            -%}
            {%- unless show_menu_item -%}
              {%- continue -%}
            {%- endunless -%}
            {%- assign has_children = false -%}
            {%- for child in section.blocks -%}
              {%- if child.type == 'menu_child' and child.settings.parent == block.settings.handle -%}
                {%- assign has_children = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            <li {{ block.shopify_attributes }}>
              {%- if has_children -%}
                <button
                  type="button"
                  class="dty-mobile-nav__link"
                  data-mobile-nav-next="{{ block.settings.handle }}"
                >
                  {{ block.settings.title }}
                  <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                </button>
              {%- else -%}
                <a href="{{ block.settings.url }}" class="dty-mobile-nav__link">
                  {{ block.settings.title }}
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}

        <li>
          <a href="{{ section.settings.quote_url }}" class="dty-mobile-nav__link">{{ 'header.quote' | t }}</a>
        </li>
        <li>
          <a href="{{ section.settings.track_url }}" class="dty-mobile-nav__link">{{ 'header.track_order' | t }}</a>
        </li>
      </ul>

      <div class="dty-mobile-nav__help">
        <p class="dty-mobile-nav__help-title">{{ 'header.help_title' | t }}</p>
        {%- if section.settings.help_phone != blank -%}
          <a href="tel:{{ section.settings.help_phone | replace: ' ', '' }}" class="dty-mobile-nav__help-item">
            <span class="material-symbols-outlined" aria-hidden="true">call</span>
            {{ section.settings.help_phone }}
          </a>
        {%- endif -%}
        {%- if section.settings.help_email != blank -%}
          <a href="mailto:{{ section.settings.help_email }}" class="dty-mobile-nav__help-item">
            <span class="material-symbols-outlined" aria-hidden="true">mail</span>
            {{ section.settings.help_email }}
          </a>
        {%- endif -%}

        {%- if section.settings.social_facebook != blank or section.settings.social_instagram != blank or section.settings.social_youtube != blank -%}
          <nav class="dty-mobile-nav__social" aria-label="{{ 'footer.social_media' | t }}">
            {% render 'dty-social-links', settings: section.settings, link_class: 'dty-mobile-nav__social-link' %}
          </nav>
        {%- endif -%}
      </div>

      <div class="dty-mobile-nav__localization">
        {% render 'dty-localization', class_prefix: 'dty-localization dty-localization--mobile', form_id: 'MobileLocalizationForm', compact: true %}
      </div>
    </div>

    {%- comment -%} Level 2 panels (one per parent menu item with children) {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu_item' -%}
        {%- assign parent_handle = block.settings.handle -%}
        {%- assign child_count = 0 -%}
        {%- for child in section.blocks -%}
          {%- if child.type == 'menu_child' and child.settings.parent == parent_handle -%}
            {%- assign child_count = child_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if child_count > 0 -%}
          <div class="dty-mobile-nav__panel" data-mobile-panel="{{ parent_handle }}">
            <div class="dty-mobile-nav__panel-header">
              <button type="button" class="dty-mobile-nav__back" data-mobile-nav-back>
                <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                {{ 'general.back' | t }}
              </button>
              <span class="dty-mobile-nav__panel-title">{{ block.settings.title }}</span>
            </div>
            <ul class="dty-mobile-nav__list">
              {%- for child in section.blocks -%}
                {%- if child.type == 'menu_child' and child.settings.parent == parent_handle -%}
                  {%- assign has_grandchildren = false -%}
                  {%- for grand in section.blocks -%}
                    {%- if grand.type == 'menu_grandchild' and grand.settings.parent == child.settings.handle -%}
                      {%- assign has_grandchildren = true -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}

                  <li {{ child.shopify_attributes }}>
                    {%- if has_grandchildren -%}
                      <button
                        type="button"
                        class="dty-mobile-nav__link"
                        data-mobile-nav-next="{{ child.settings.handle }}"
                      >
                        {{ child.settings.title }}
                        <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
                      </button>
                    {%- else -%}
                      <a href="{{ child.settings.url }}" class="dty-mobile-nav__link">
                        {{ child.settings.title }}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Level 3 panels {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu_child' -%}
        {%- assign child_handle = block.settings.handle -%}
        {%- assign grand_count = 0 -%}
        {%- for grand in section.blocks -%}
          {%- if grand.type == 'menu_grandchild' and grand.settings.parent == child_handle -%}
            {%- assign grand_count = grand_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if grand_count > 0 -%}
          <div class="dty-mobile-nav__panel" data-mobile-panel="{{ child_handle }}">
            <div class="dty-mobile-nav__panel-header">
              <button type="button" class="dty-mobile-nav__back" data-mobile-nav-back>
                <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                {{ 'general.back' | t }}
              </button>
              <span class="dty-mobile-nav__panel-title">{{ block.settings.title }}</span>
            </div>
            <ul class="dty-mobile-nav__list">
              {%- for grand in section.blocks -%}
                {%- if grand.type == 'menu_grandchild' and grand.settings.parent == child_handle -%}
                  <li {{ grand.shopify_attributes }}>
                    <a href="{{ grand.settings.url }}" class="dty-mobile-nav__link">
                      {{ grand.settings.title }}
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</nav>
